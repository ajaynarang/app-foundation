{
  "name": "app-foundation",
  "version": "0.1.0",
  "private": true,
  "description": "app-foundation — domain-free platform starter",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "// — Make it yours (rename the template)": "",
    "init-app": "node tools/init-app/init-app.mjs",
    "// — Turbo (all apps)": "",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky || true",
    "// — Backend shortcuts": "",
    "backend:dev": "turbo run dev --filter=@app/backend",
    "backend:build": "turbo run build --filter=@app/backend",
    "backend:test": "turbo run test --filter=@app/backend",
    "backend:db:push": "pnpm --filter @appshore/db db:push",
    "backend:seed": "pnpm --filter @appshore/db db:seed",
    "backend:prisma:generate": "pnpm --filter @appshore/db prisma:generate",
    "backend:prisma:studio": "pnpm --filter @appshore/db prisma:studio",
    "// — Frontend shortcuts": "",
    "frontend:dev": "turbo run dev --filter=@app/web",
    "console:dev": "turbo run dev --filter=@app/console",
    "// — Docker (PostgreSQL, Redis, Inngest; optional Loki/Tempo/Grafana via --profile observability)": "",
    "docker:up": "docker compose up -d",
    "docker:build": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:restart": "docker compose restart",
    "// — Doppler (dev with secrets injection)": "",
    "doppler:backend": "cd apps/backend && doppler run -- pnpm run dev",
    "doppler:frontend": "cd apps/web && doppler run -- pnpm run dev",
    "doppler:console": "cd apps/console && doppler run -- pnpm run dev",
    "// — Side-by-side dev (opens iTerm2 tabs with custom ports)": "",
    "dev:side": "./tools/dev/app-dev.sh ",
    "dev:side:stop": "./tools/dev/app-dev.sh --stop",
    "// — Inngest (Desk durable workflow engine — local dev)": "",
    "inngest:dev": "npx inngest-cli@latest dev -u http://localhost:8000/api/v1/inngest",
    "// — QA (tests/) — all config (API_BASE_URL, WEB_BASE_URL, DEV_AUTH_SECRET) from Doppler app-backend/dev.": "",
    "test:qa": "pnpm --filter @app/qa test",
    "test:qa:local": "doppler run --project app-backend --config dev -- pnpm --filter @app/qa test",
    "test:smoke:local": "doppler run --project app-backend --config dev -- pnpm --filter @app/qa test:smoke",
    "test:rbac:local": "doppler run --project app-backend --config dev -- pnpm --filter @app/qa test:rbac",
    "test:api:local": "doppler run --project app-backend --config dev -- pnpm --filter @app/qa test:api",
    "test:browser:local": "doppler run --project app-backend --config dev -- pnpm --filter @app/qa test:browser",
    "qa:report": "pnpm --filter @app/qa report",
    "qa:list-tenants": "doppler run --project app-backend --config dev -- pnpm --filter @app/qa list-tenants",
    "qa:enable-features": "doppler run --project app-backend --config dev -- pnpm --filter @app/qa qa:enable-features"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.0",
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yaml,yml}": [
      "prettier --write --ignore-path .prettierignore"
    ]
  }
}
