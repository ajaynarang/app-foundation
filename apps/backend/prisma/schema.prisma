  FLEET
}

model Alert {
  id       Int    @id @default(autoincrement())
  alertId  String @unique @map("alert_id") @db.VarChar(50)
  tenantId Int    @map("tenant_id")

  // Context — Int FKs (Phase 2 Task 10). All NULLABLE: alerts are legitimately
  // emitted for entities that may not exist (system alerts: trial expiry,
  // fleet-limit) or may later be deleted (ON DELETE SET NULL preserves the
  // historical record instead of cascading the delete).
  driverId    Int? @map("driver_id")
  routePlanId Int? @map("route_plan_id")
  vehicleId   Int? @map("vehicle_id")
  loadId      Int? @map("load_id")

  // Scope
  scope AlertScope @default(LOAD)

  // Classification
  alertType String        @map("alert_type") @db.VarChar(50)
  category  String        @default("system") @db.VarChar(30)
  priority  AlertPriority

  // Content
  title             String  @db.VarChar(200)
  message           String  @db.Text
  recommendedAction String? @map("recommended_action") @db.Text
  metadata          Json?   @db.JsonB

  // Lifecycle
  status            AlertStatus @default(ACTIVE)
  acknowledgedAt    DateTime?   @map("acknowledged_at") @db.Timestamptz
  acknowledgedBy    String?     @map("acknowledged_by") @db.VarChar(50)
  snoozedUntil      DateTime?   @map("snoozed_until") @db.Timestamptz
  resolvedAt        DateTime?   @map("resolved_at") @db.Timestamptz
  resolvedBy        String?     @map("resolved_by") @db.VarChar(50)
  resolutionNotes   String?     @map("resolution_notes") @db.Text
  autoResolved      Boolean     @default(false) @map("auto_resolved")
  autoResolveReason String?     @map("auto_resolve_reason") @db.Text

  // Grouping
  parentAlertId Int?    @map("parent_alert_id")
  groupKey      String? @map("group_key") @db.VarChar(200)

  // Escalation
  escalationLevel Int       @default(0) @map("escalation_level")
  escalatedAt     DateTime? @map("escalated_at") @db.Timestamptz

  // Deduplication
  dedupKey String? @map("dedup_key") @db.VarChar(200)

  // Occurrence tracking (reactivation instead of duplicate creation)
  occurrenceCount            Int       @default(1) @map("occurrence_count")
  lastOccurredAt             DateTime? @map("last_occurred_at") @db.Timestamptz
  manualResolveCooldownUntil DateTime? @map("manual_resolve_cooldown_until") @db.Timestamptz

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  notes       AlertNote[]
  parentAlert Alert?      @relation("AlertGroup", fields: [parentAlertId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  childAlerts Alert[]     @relation("AlertGroup")
  driver      Driver?     @relation(fields: [driverId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  load        Load?       @relation(fields: [loadId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  routePlan   RoutePlan?  @relation(fields: [routePlanId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  vehicle     Vehicle?    @relation(fields: [vehicleId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([tenantId, status, priority, createdAt])
  @@index([tenantId, createdAt])
  @@index([dedupKey, status])
  @@index([driverId, status])
  @@index([routePlanId, status])
  @@index([loadId, status])
  @@index([parentAlertId])
  @@index([groupKey])
  @@index([snoozedUntil])
  @@index([scope, status])
  @@map("alerts")
}

