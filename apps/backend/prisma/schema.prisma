  // Physical dimensions for truck-aware routing (low bridges, length/axle limits).
  heightInches         Float?    @map("height_inches")
  lengthInches         Float?    @map("length_inches")
  axleCount            Int?      @map("axle_count")
  notes                String?   @db.Text
