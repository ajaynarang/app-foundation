  deactivatedByUser  User?                  @relation("TrailerDeactivatedBy", fields: [deactivatedBy], references: [id])
  deactivationReason String?                @map("deactivation_reason")
  reactivatedAt      DateTime?              @map("reactivated_at") @db.Timestamptz
  reactivatedBy      Int?                   @map("reactivated_by")
  reactivatedByUser  User?                  @relation("TrailerReactivatedBy", fields: [reactivatedBy], references: [id])

  // Ownership
  ownershipType OwnershipType? @map("ownership_type")

  // Current vehicle assignment
  assignedVehicleId Int?     @unique @map("assigned_vehicle_id")
  assignedVehicle   Vehicle? @relation("CurrentTrailer", fields: [assignedVehicleId], references: [id])

  // Tenant
  tenantId Int    @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

