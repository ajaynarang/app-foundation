generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// AUTHENTICATION & MULTI-TENANCY MODELS
// ============================================================================

enum UserRole {
  DISPATCHER
  DRIVER
  ADMIN
  OWNER // Tenant owner - created during registration, cannot be deleted
  CUSTOMER // External customer/shipper with limited portal access
  SUPER_ADMIN
}

enum TenantStatus {
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  SUSPENDED
}

enum TenantPlan {
  TRIAL
  TRIAL_EXPIRED
  STARTER
  PROFESSIONAL
  ENTERPRISE
  SUSPENDED
}

enum BundleFormat {
  ZIP
  MERGED_PDF

  @@map("bundle_format")
}

enum FleetSize {
  SIZE_1_10     @map("1-10")
  SIZE_11_50    @map("11-50")
  SIZE_51_100   @map("51-100")
  SIZE_101_500  @map("101-500")
  SIZE_500_PLUS @map("500+")
}

enum CarrierType {
  FOR_HIRE_INTERSTATE @map("for_hire_interstate")
  INTRASTATE_ONLY     @map("intrastate_only")
  PRIVATE_FLEET       @map("private_fleet")
  LEASED_ON           @map("leased_on")
}

// How a facility admits trucks relative to its appointment window.
// FCFS = first-come-first-served; APPOINTMENT_STRICT = no early entry (wait offsite);
// LOOSE = early entry tolerated.
enum StopEntryPolicy {
  FCFS
  APPOINTMENT_STRICT
  LOOSE
}

// FMCSA duty status for stateful HOS clocks (49 CFR 395). ELD wire codes are
// lowercase; this DB enum is the canonical stored form.
enum DriverDutyStatus {
  DRIVING
  ON_DUTY
  OFF_DUTY
  SLEEPER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  CANCELLED
  EXPIRED
}

enum InvitationChannel {
  EMAIL
  SMS
}

enum SupportCategory {
  BILLING
  TECHNICAL
  FEATURE_REQUEST
  ACCOUNT
  INTEGRATION
  GENERAL
}

enum SupportPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  RESOLVED
  CLOSED
}

enum BillingProviderType {
  STRIPE
}

enum BillingSubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  SUSPENDED
  TRIALING
}

enum BillingInvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum PaymentMethodType {
  CARD
  US_BANK_ACCOUNT
}

enum WalletTransactionType {
  TOP_UP
  OVERAGE_DEDUCTION
  ADMIN_CREDIT
  REFUND
  AUTO_RELOAD
}

enum CustomFieldEntityType {
  LOAD
  DRIVER
  VEHICLE
  CUSTOMER
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
}

model CustomFieldDefinition {
  id             Int                   @id @default(autoincrement())
  tenantId       Int                   @map("tenant_id")
  tenant         Tenant                @relation(fields: [tenantId], references: [id])
  entityType     CustomFieldEntityType @map("entity_type")
  name           String                @db.VarChar(100)
  fieldKey       String                @map("field_key") @db.VarChar(50)
  fieldType      CustomFieldType       @map("field_type")
  options        String[]              @default([])
  isRequired     Boolean               @default(false) @map("is_required")
  driverEditable Boolean               @default(false) @map("driver_editable")
  sortOrder      Int                   @default(0) @map("sort_order")
  isActive       Boolean               @default(true) @map("is_active")
  showOnInvoice  Boolean               @default(false) @map("show_on_invoice")
  showOnBol      Boolean               @default(false) @map("show_on_bol")
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, entityType, fieldKey], name: "uq_tenant_entity_fieldkey")
  @@index([tenantId, entityType, isActive], name: "idx_tenant_entity_active")
  @@map("custom_field_definitions")
}

model Tenant {
  id           Int     @id @default(autoincrement())
  tenantId     String  @unique @map("tenant_id") @db.VarChar(50)
  companyName  String  @map("company_name") @db.VarChar(255)
  subdomain    String? @unique @db.VarChar(100)
  contactEmail String? @map("contact_email") @db.VarChar(255)
  contactPhone String? @map("contact_phone") @db.VarChar(50)

  // Registration fields
  status      TenantStatus @default(PENDING_APPROVAL)
  dotNumber   String?      @map("dot_number") @db.VarChar(8)
  carrierType CarrierType  @default(FOR_HIRE_INTERSTATE) @map("carrier_type")
  mcNumber    String?      @map("mc_number") @db.VarChar(8)
  fleetSize   FleetSize?   @map("fleet_size")

  // Approval tracking
  approvedAt      DateTime? @map("approved_at") @db.Timestamptz
  approvedBy      String?   @map("approved_by") @db.VarChar(100)
  rejectedAt      DateTime? @map("rejected_at") @db.Timestamptz
  rejectionReason String?   @map("rejection_reason")

  // Suspension tracking
  suspendedAt      DateTime? @map("suspended_at") @db.Timestamptz
  suspendedBy      String?   @map("suspended_by") @db.VarChar(100)
  suspensionReason String?   @map("suspension_reason")

  // Reactivation tracking
  reactivatedAt DateTime? @map("reactivated_at") @db.Timestamptz
  reactivatedBy String?   @map("reactivated_by") @db.VarChar(100)

  // Onboarding tracking
  onboardingCompletedAt DateTime? @map("onboarding_completed_at") @db.Timestamptz
  onboardingProgress    Json?     @map("onboarding_progress") @db.JsonB

  // Timezone for scheduled Desk responsibilities (IANA identifier, e.g. "America/Chicago")
  timezone String? @default("UTC") @db.VarChar(60)

  // Tenant-wide master switch for autonomous Desk runs. When false (default),
  // NO responsibility runs autonomously regardless of per-responsibility
  // `autonomyEnabled` — the scheduler (and any future non-manual trigger)
  // skips the whole tenant. A one-flip "pause all autonomous runs" safety
  // control. Manual "Run now" is unaffected. (Column name kept as
  // `deskScheduleEnabled` for migration stability.)
  deskScheduleEnabled Boolean @default(false) @map("desk_schedule_enabled")

  // When true, this tenant's AI traffic must route through zero-data-retention
  // (ZDR) provider endpoints — no prompt/response retention at the provider.
  // Enforced in AiProvider.resolveModel; if no ZDR-eligible model exists for
  // the requested tier, the call throws ZeroRetentionUnavailable. For
  // compliance-sensitive customers.
  aiZeroRetention Boolean @default(false) @map("ai_zero_retention")

  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Plan & billing
  plan              TenantPlan @default(TRIAL) @map("plan")
  trialStartedAt    DateTime?  @map("trial_started_at") @db.Timestamptz
  trialEndsAt       DateTime?  @map("trial_ends_at") @db.Timestamptz
  planAssignedAt    DateTime?  @map("plan_assigned_at") @db.Timestamptz
  planAssignedBy    String?    @map("plan_assigned_by") @db.VarChar(100)
  fleetLimitWarning Boolean    @default(false) @map("fleet_limit_warning")

  // Job control
  jobsPaused   Boolean   @default(false) @map("jobs_paused")
  jobsPausedAt DateTime? @map("jobs_paused_at") @db.Timestamptz
  jobsPausedBy Int?      @map("jobs_paused_by")

  // Factoring default — single source of truth for "our factor" (Phase 1 overhaul)
  defaultFactoringCompanyId Int?              @map("default_factoring_company_id")
  defaultFactoringCompany   FactoringCompany? @relation("TenantDefaultFactoringCompany", fields: [defaultFactoringCompanyId], references: [id], onDelete: SetNull)

  // Bundle format for factor email attachments (factoring cleanup). ZIP is the
  // safer/universal default; MERGED_PDF preserves Phase 2 behavior for tenants
  // whose factor specifically requires a single combined PDF.
  bundleFormat BundleFormat @default(ZIP) @map("bundle_format")

  // Phase 4 — driver pay timing. Default ON_DELIVERY preserves current behavior
  // (settlements trigger on load delivery). ON_FACTOR_FUND gates settlement
  // creation on Invoice.advanceReceivedAt being set.
  driverPayTiming DriverPayTiming @default(ON_DELIVERY) @map("driver_pay_timing")

  users                       User[]
  loginEvents                 LoginEvent[]
  drivers                     Driver[]
  vehicles                    Vehicle[]
  routePlans                  RoutePlan[]
  alerts                      Alert[]
  integrationConfigs          IntegrationConfig[]
  fleetOperationsSettings     FleetOperationsSettings?
  invitations                 UserInvitation[]
  notifications               Notification[]
  alertConfiguration          AlertConfiguration?
  loads                       Load[]
  customers                   Customer[]
  shiftNotes                  ShiftNote[]
  conversations               Conversation[]
  supportTickets              SupportTicket[]
  vehicleTelematics           VehicleTelematics[]
  invoices                    Invoice[]
  settlements                 Settlement[]
  payments                    Payment[]
  driverPayStructures         DriverPayStructure[]
  customerContacts            CustomerContact[]
  jobs                        Job[]
  counters                    TenantCounter[]
  planEvents                  TenantPlanEvent[]
  webhookSubscriptions        WebhookSubscription[]
  domainEventLogs             DomainEventLog[]
  deadLetters                 DeadLetterLog[]
  shieldAudits                ShieldAudit[]
  shieldFindings              ShieldFinding[]
  shieldCustomRules           ShieldCustomRule[]
  vehicleDvirs                VehicleDVIR[]
  trailers                    Trailer[]
  trailerDvirs                TrailerDVIR[]
  documents                   Document[]
  recurringLanes              RecurringLane[]
  invoiceSettings             InvoiceSettings?
  invoiceShareLinks           InvoiceShareLink[]
  loadShareLinks              LoadShareLink[]
  conversationSessions        ConversationSession[]
  factoringCompanies          FactoringCompany[]
  noaRecords                  NoaRecord[]
  factoringTransactions       FactoringTransaction[]
  factoringContacts           FactoringContact[]
  billingOverrides            BillingOverride[]
  accountingAccountMappings   AccountingAccountMapping[]
  integrationExternalEntities IntegrationExternalEntity[]
  integrationEntityMappings   IntegrationEntityMapping[]
  oauthClients                OAuthClient[]
  ediTradingPartners          EDITradingPartner[]
  ediMessages                 EDIMessage[]
  ediAutoAcceptRules          EDIAutoAcceptRule[]
  tenantAddOns                TenantAddOn[]
  tenantAddOnEvents           TenantAddOnEvent[]
  addOnRequests               AddOnRequest[]
  iftaQuarters                IftaQuarter[]
  iftaStateMileage            IftaStateMileage[]
  iftaFuelPurchases           IftaFuelPurchase[]
  iftaFilings                 IftaFiling[]
  loadBoardSavedSearches      LoadBoardSavedSearch[]
  feedback                    Feedback[]
  emailIngestSettings         EmailIngestSettings?
  emailIngestThreads          EmailIngestThread[]
  routePlanFeedback           RoutePlanFeedback[]

  // Billing & wallet
  billingCustomer          BillingCustomer?
  billingSubscriptions     BillingSubscription[]
  wallet                   Wallet?
  walletTransactions       WalletTransaction[]
  billingInvoices          BillingInvoice[]
  paymentMethods           PaymentMethod[]
  loadLegs                 LoadLeg[]
  moneyCodes               MoneyCode[]
  driverActionRequests     DriverActionRequest[]
  laneRateTargets          LaneRateTarget[]
  driverUnavailabilities   DriverUnavailability[]
  vehicleUnavailabilities  VehicleUnavailability[]
  customFieldDefinitions   CustomFieldDefinition[]
  trips                    Trip[]
  deskAgents               DeskAgent[]
  deskResponsibilities     DeskResponsibility[]
  deskEpisodes             DeskEpisode[]
  deskMemories             DeskMemory[]
  deskEntitySuppressions   DeskEntitySuppression[]
  tenantJobRuns            TenantJobRun[]
  driverFleetPreferences   DriverFleetPreferences[]
  driverPerformanceMetrics DriverPerformanceMetrics[]
  laneRateHistory          LaneRateHistory[]
  agentInvocationLogs      AgentInvocationLog[]
  hitlChallenges           HitlChallenge[]
  aiInvocations            AiInvocation[]
  aiBudget                 TenantAiBudget?

  @@index([status])
  @@index([dotNumber])
  // Serves the every-minute scheduler heartbeat scan for tenants with the
  // master Desk-autonomy switch on (desk-scheduler.processor.ts).
  @@index([deskScheduleEnabled])
  @@map("tenants")
}

model User {
  id     Int    @id @default(autoincrement())
  userId String @unique @map("user_id") @db.VarChar(50)

  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  tenantId Int?    @map("tenant_id")

  email        String?  @db.VarChar(255)
  passwordHash String?  @map("password_hash") @db.VarChar(255)
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  role         UserRole

  // Firebase integration
  firebaseUid   String? @unique @map("firebase_uid") @db.VarChar(128)
  emailVerified Boolean @default(false) @map("email_verified")

  // Phone authentication
  phone         String? @unique @db.VarChar(20)
  phoneVerified Boolean @default(false) @map("phone_verified")
  pinHash       String? @map("pin_hash") @db.VarChar(255)

  // Driver link (optional, only for DRIVER role)
  driver   Driver? @relation(fields: [driverId], references: [id])
  driverId Int?    @unique @map("driver_id")

  // Customer link (optional, only for CUSTOMER role)
  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId Int?      @unique @map("customer_id")

  // Status tracking
  isActive          Boolean   @default(true) @map("is_active")
  lastLoginAt       DateTime? @map("last_login_at") @db.Timestamptz
  passwordChangedAt DateTime? @map("password_changed_at") @db.Timestamptz

  // Soft delete
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz
  deletedBy      Int?      @map("deleted_by")
  deletedByUser  User?     @relation("DeletedBy", fields: [deletedBy], references: [id])
  deletedUsers   User[]    @relation("DeletedBy")
  deletionReason String?   @map("deletion_reason")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  refreshTokens                  RefreshToken[]
  loginEvents                    LoginEvent[]
  apiKeys                        ApiKey[]
  preferences                    UserPreferences?
  driverPreferences              DriverPreferences?
  superAdminPreferences          SuperAdminPreferences?
  invitationsSent                UserInvitation[]         @relation("InvitedBy")
  invitationsAccepted            UserInvitation[]         @relation("AcceptedBy")
  driversActivated               Driver[]                 @relation("ActivatedBy")
  driversDeactivated             Driver[]                 @relation("DeactivatedBy")
  driversReactivated             Driver[]                 @relation("ReactivatedBy")
  customersDeactivated           Customer[]               @relation("CustomerDeactivatedBy")
  customersReactivated           Customer[]               @relation("CustomerReactivatedBy")
  vehiclesDeactivated            Vehicle[]                @relation("VehicleDeactivatedBy")
  vehiclesReactivated            Vehicle[]                @relation("VehicleReactivatedBy")
  trailersDeactivated            Trailer[]                @relation("TrailerDeactivatedBy")
  trailersReactivated            Trailer[]                @relation("TrailerReactivatedBy")
  notifications                  Notification[]
  pushSubscriptions              PushSubscription[]
  shiftNotes                     ShiftNote[]
  acknowledgedShiftNotes         ShiftNote[]              @relation("ShiftNoteAcknowledger")
  conversations                  Conversation[]
  jobsSubmitted                  Job[]                    @relation("jobsSubmitted")
  shieldAuditsTriggered          ShieldAudit[]            @relation("shieldAuditsTriggered")
  shieldFindingsResolved         ShieldFinding[]          @relation("shieldFindingsResolved")
  shieldFindingsDisputed         ShieldFinding[]          @relation("shieldFindingsDisputed")
  shieldCustomRulesCreated       ShieldCustomRule[]       @relation("shieldCustomRulesCreated")
  billingOverrides               BillingOverride[]
  oauthClientsCreated            OAuthClient[]            @relation("OAuthClientCreator")
  oauthAuthorizationCodes        OAuthAuthorizationCode[]
  oauthAccessTokens              OAuthAccessToken[]
  oauthRefreshTokens             OAuthRefreshToken[]
  iftaQuartersFiled              IftaQuarter[]            @relation("iftaQuartersFiled")
  iftaFuelPurchasesCreated       IftaFuelPurchase[]       @relation("iftaFuelPurchasesCreated")
  loadBoardSavedSearches         LoadBoardSavedSearch[]
  feedbackSubmitted              Feedback[]               @relation("FeedbackSubmitter")
  feedbackResolved               Feedback[]               @relation("FeedbackResolver")
  supportTicketsCreated          SupportTicket[]          @relation("supportTicketCreator")
  supportMessages                SupportTicketMessage[]   @relation("supportMessageAuthor")
  announcements                  Announcement[]           @relation("AnnouncementCreatedBy")
  routePlanFeedback              RoutePlanFeedback[]
  approvedMoneyCodes             MoneyCode[]              @relation("MoneyCodeApprover")
  acknowledgedActions            DriverActionRequest[]    @relation("ActionRequestAcknowledger")
  createdDriverUnavailabilities  DriverUnavailability[]
  createdVehicleUnavailabilities VehicleUnavailability[]
  createdTrips                   Trip[]                   @relation("TripCreatedBy")
  driverFleetPreferencesSet      DriverFleetPreferences[]
  supervisedDeskAgents           DeskAgent[]              @relation("DeskAgentSupervisor")
  deskApprovalsClaimed           DeskApproval[]           @relation("DeskApprovalClaimedBy")
  deskApprovalsDecided           DeskApproval[]           @relation("DeskApprovalDecidedBy")
  deskSuppressionsSet            DeskEntitySuppression[]  @relation("DeskSuppressionSet")
  deskSuppressionsUnset          DeskEntitySuppression[]  @relation("DeskSuppressionUnset")
  deskMemoriesAuthored           DeskMemory[]             @relation("DeskMemoryAuthoredBy")
  aiInvocations                  AiInvocation[]

  @@index([tenantId])
  @@index([email])
  @@index([phone])
  @@index([firebaseUid])
  @@index([role])
  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

model SuperAdminPreferences {
  id     Int  @id @default(autoincrement())
  userId Int  @unique @map("user_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  notifyNewTenants      Boolean @default(true) @map("notify_new_tenants")
  notifyStatusChanges   Boolean @default(true) @map("notify_status_changes")
  notificationFrequency String  @default("immediate") @map("notification_frequency") @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([userId])
  @@map("super_admin_preferences")
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  tokenId   String    @unique @map("token_id") @db.VarChar(50)
  userId    Int       @map("user_id")
  token     String    @db.VarChar(500)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  isRevoked Boolean   @default(false) @map("is_revoked")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

enum LoginEventStatus {
  SUCCESS
  FAILED
  LOGOUT
}

enum LoginFailReason {
  ACCOUNT_DISABLED
  TENANT_INACTIVE
  INVALID_TOKEN
  USER_NOT_FOUND
  OTHER

  @@map("login_fail_reason")
}

model LoginEvent {
  id         Int              @id @default(autoincrement())
  userId     Int              @map("user_id")
  tenantId   Int?             @map("tenant_id")
  status     LoginEventStatus
  ip         String?          @db.VarChar(45)
  userAgent  String?          @map("user_agent") @db.Text
  deviceId   String?          @map("device_id") @db.VarChar(64)
  failReason LoginFailReason? @map("fail_reason")
  sessionId  String?          @map("session_id") @db.VarChar(50)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
  @@index([createdAt])
  @@index([tenantId, status, createdAt(sort: Desc)], name: "idx_login_event_tenant_status_created")
  @@index([tenantId, userId, createdAt(sort: Desc)], name: "idx_login_event_tenant_user_created")
  @@map("login_events")
}

model ApiKey {
  id     Int    @id @default(autoincrement())
  key    String @unique @db.VarChar(64)
  name   String @db.VarChar(255)
  userId Int    @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Usage tracking
  lastUsedAt   DateTime? @map("last_used_at") @db.Timestamptz
  requestCount Int       @default(0) @map("request_count")

  // Rate limiting (legacy unused column — kept for backwards compatibility; new code uses rateLimitPerMinute)
  rateLimit Int @default(1000) @map("rate_limit")

  // Phase B — scoped keys
  scopes              String[] @default([])
  ipAllowlist         String[] @default([]) @map("ip_allowlist")
  rateLimitPerMinute  Int      @default(300) @map("rate_limit_per_minute")
  isWriteEnabled      Boolean  @default(false) @map("is_write_enabled")
  lastValidationError String?  @map("last_validation_error") @db.Text

  // Status
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  expiresAt DateTime? @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz

  @@index([userId])
  @@index([key])
  @@index([userId, revokedAt])
  @@map("api_keys")
}

model UserInvitation {
  id           Int    @id @default(autoincrement())
  invitationId String @unique @default(uuid()) @map("invitation_id")

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId Int    @map("tenant_id")

  email         String?           @db.VarChar(255)
  phone         String?           @db.VarChar(20)
  inviteChannel InvitationChannel @default(EMAIL) @map("invite_channel")
  firstName     String            @map("first_name") @db.VarChar(100)
  lastName      String            @map("last_name") @db.VarChar(100)
  role          UserRole

  // Optional driver link (for DRIVER role invitations)
  driverId Int?    @map("driver_id")
  driver   Driver? @relation(fields: [driverId], references: [id])

  // Optional customer link (for CUSTOMER role invitations)
  customerId Int?      @map("customer_id")
  customer   Customer? @relation(fields: [customerId], references: [id])

  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz

  invitedBy     Int  @map("invited_by")
  invitedByUser User @relation("InvitedBy", fields: [invitedBy], references: [id])

  status           InvitationStatus @default(PENDING)
  acceptedAt       DateTime?        @map("accepted_at") @db.Timestamptz
  acceptedByUserId Int?             @map("accepted_by_user_id")
  acceptedByUser   User?            @relation("AcceptedBy", fields: [acceptedByUserId], references: [id])

  cancelledAt        DateTime? @map("cancelled_at") @db.Timestamptz
  cancellationReason String?   @map("cancellation_reason")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  notifications Notification[]

  @@index([tenantId])
  @@index([token])
  @@index([email])
  @@index([expiresAt])
  @@index([status])
  @@index([driverId])
  @@index([customerId])
  @@map("user_invitations")
}

// ============================================================================
// EXISTING MODELS (UPDATED FOR MULTI-TENANCY)
// ============================================================================

enum DriverStatus {
  PENDING_ACTIVATION
  ACTIVE
  INACTIVE
  SUSPENDED
  REMOVED_FROM_SOURCE
}

enum SyncStatus {
  SYNCED
  REMOVED
  SYNC_ERROR
  MANUAL_ENTRY
}

enum CdlClass {
  A
  B
  C
}

model Driver {
  id       Int    @id @default(autoincrement())
  driverId String @unique @map("driver_id") @db.VarChar(50)

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId Int    @map("tenant_id")

  name          String    @db.VarChar(255)
  licenseNumber String?   @map("license_number") @db.VarChar(50)
  licenseState  String?   @map("license_state") @db.VarChar(2)
  phone         String?   @db.VarChar(20)
  email         String?   @db.VarChar(255)
  cdlClass      CdlClass? @map("cdl_class")
  endorsements  String[]  @default([])

  // Status management
  status DriverStatus @default(PENDING_ACTIVATION)

  // Activation tracking
  activatedAt     DateTime? @map("activated_at") @db.Timestamptz
  activatedBy     Int?      @map("activated_by")
  activatedByUser User?     @relation("ActivatedBy", fields: [activatedBy], references: [id])

  // Deactivation tracking
  deactivatedAt      DateTime? @map("deactivated_at") @db.Timestamptz
  deactivatedBy      Int?      @map("deactivated_by")
  deactivatedByUser  User?     @relation("DeactivatedBy", fields: [deactivatedBy], references: [id])
  deactivationReason String?   @map("deactivation_reason")

  // Reactivation tracking
