/// Short-lived HITL challenge issued when an external principal attempts a write
/// on a scope whose tier is 'standard' or 'sensitive'. The principal must either
/// re-present the token within TTL (standard) or complete an OTP step-up and then
/// re-present it (sensitive) before the real tool call is executed.
model HitlChallenge {
  id       Int    @id @default(autoincrement())
  tenantId Int    @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  principalKind String @map("principal_kind") @db.VarChar(32)
  principalId   String @map("principal_id") @db.VarChar(128)

  toolName      String @map("tool_name") @db.VarChar(80)
  argsDigest    String @map("args_digest") @db.VarChar(64)
  scopeRequired String @map("scope_required") @db.VarChar(60)
  tier          String @db.VarChar(16)

  stepUpRequired  Boolean @default(false) @map("step_up_required")
  stepUpUserId    Int?    @map("step_up_user_id")
  stepUpCompleted Boolean @default(false) @map("step_up_completed")

  consumedAt DateTime? @map("consumed_at") @db.Timestamptz
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([tenantId, expiresAt])
  @@index([tenantId, principalId, consumedAt])
  @@map("hitl_challenges")
}

// =============================================================================
// AI Cost Telemetry
// =============================================================================
//
// `AiInvocation` is the single LLM/embedding call ledger across every Sally AI
// surface (chat, desk steps, document intelligence, alert briefings, memory,
// embeddings, knowledge-base ingest). One row per model call. Cost is computed
// at write time from `ModelPricing` and denormalized so historical totals stay
// accurate when prices change.
//
// Distinct from `AgentInvocationLog` above, which audits tool-call metadata
// (tool name, scope, HITL tier, args). A single tool call may have multiple
// `AiInvocation` rows linked via `parentInvocationId`. They answer different
// questions and intentionally stay separate.
//
// Wired through `AiTelemetryService` (PR 1 introduces the table + service;
// PR 2-4 wire callers; PR 5 adds super-admin views).

/// Surface that produced an AI invocation. Used for cost attribution and
/// per-surface budget enforcement. New surfaces are added here, not in code.
enum AiSurface {
  SALLY_CHAT
  DESK_STEP
  DOC_RATECON
  DOC_FUEL_RECEIPT
  ALERT_BRIEFING
  MEMORY_EXTRACT
  EMBEDDING
  KB_INGEST
}

/// Terminal status of an AI invocation as observed by the wrapper.
/// `BUDGET_BLOCKED` is reserved for PR 7 (pre-call cost-budget check) and is
/// declared now so the enum doesn't need a second migration in sprint 2.
enum AiInvocationStatus {
  OK
  ERROR
  TIMEOUT
  RATE_LIMITED
  BUDGET_BLOCKED
}

/// Append-only ledger of every LLM and embedding call. Indexed for tenant +
/// surface + time queries; read-side views (vw_ai_cost_daily,
/// vw_ai_cost_per_tenant, vw_ai_cost_per_episode) are introduced in PR 5.
model AiInvocation {
  /// UUIDv7, generated via generateUuidV7() in shared/utils/uuidv7.ts.
  /// See id-convention.md Rule 2 (audit / event / log PKs).
  id       String @id @db.Uuid
  tenantId Int    @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId Int?  @map("user_id")
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  surface  AiSurface
  agentId  String?   @map("agent_id") @db.VarChar(80)
  model    String    @db.VarChar(80)
  provider String    @db.VarChar(40)

  promptTokens     Int  @default(0) @map("prompt_tokens")
  completionTokens Int  @default(0) @map("completion_tokens")
  totalTokens      Int  @default(0) @map("total_tokens")
  cachedTokens     Int? @map("cached_tokens")

  /// Denormalized cost in USD computed at write time from `ModelPricing`. Null
  /// when no matching pricing row was found (the call still gets recorded —
  /// untagged cost is a bug, not a default).
  costUsd   Decimal? @map("cost_usd") @db.Decimal(12, 6)
  latencyMs Int?     @map("latency_ms")

  status    AiInvocationStatus
  errorCode String?            @map("error_code") @db.VarChar(80)

  /// Self-FK used when a single logical call produces multiple model
  /// invocations (e.g. primary + fallback retry, or a tool-call that triggers
  /// a sub-LLM-call). The fallback row references the primary's id.
  parentInvocationId String?        @map("parent_invocation_id") @db.Uuid
  parentInvocation   AiInvocation?  @relation("AiInvocationParentChild", fields: [parentInvocationId], references: [id], onDelete: SetNull)
  childInvocations   AiInvocation[] @relation("AiInvocationParentChild")

  /// Polymorphic linkage to the surface entity. Surfaces churn faster than the
  /// ledger does — we keep a typed linkRef pair here instead of one FK per
  /// surface. `DeskEpisodeStep.aiInvocationId` is the one exception (hot read
  /// path for the desk timeline).
  linkRefType String? @map("link_ref_type") @db.VarChar(40)
  linkRefId   String? @map("link_ref_id") @db.VarChar(64)

  /// Langfuse trace id when Langfuse is configured. Lets the super-admin view
  /// deep-link from a Postgres row back to the trace with prompt + response.
  langfuseTraceId String? @map("langfuse_trace_id") @db.VarChar(128)

  /// Optional idempotency key. When present, duplicate writes (e.g. retried
  /// HTTP calls inside a parser) are no-ops. Shape per
  /// `tools/db/idempotency-keys.md` (PR 9 standardizes the schema).
  idempotencyKey String? @unique @map("idempotency_key") @db.VarChar(200)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  deskEpisodeSteps DeskEpisodeStep[]

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, surface, createdAt(sort: Desc)])
  @@index([linkRefType, linkRefId])
  @@index([parentInvocationId])
  @@map("ai_invocations")
}

/// Per-provider/per-model pricing snapshot. Pricing-as-data so we can rotate
/// models without redeploys; `effectiveFromDate` lets us preserve historical
/// pricing for replay/backfill. `cachedInputPerMtokUsd` is nullable because
/// not every provider exposes a separate cached-input price.
///
/// Pricing changes are made by inserting a new row with the new
/// `effectiveFromDate` and setting `effectiveUntilDate` on the superseded
/// row — never UPDATE in place. The "price that was effective at write
/// time" semantics keep historical cost reconciliation honest. Uses
/// calendar Date (matches other Sally effective-dated tables like
/// LaneRateTarget) — pricing rotates on day boundaries, not by the second.
/// Field names carry the `Date` suffix per the schema-linter convention.
model ModelPricing {
  id                    Int       @id @default(autoincrement())
  provider              String    @db.VarChar(40)
  model                 String    @db.VarChar(80)
  inputPerMtokUsd       Decimal   @map("input_per_mtok_usd") @db.Decimal(10, 6)
  outputPerMtokUsd      Decimal   @map("output_per_mtok_usd") @db.Decimal(10, 6)
  cachedInputPerMtokUsd Decimal?  @map("cached_input_per_mtok_usd") @db.Decimal(10, 6)
  effectiveFromDate     DateTime  @map("effective_from_date") @db.Date
  effectiveUntilDate    DateTime? @map("effective_until_date") @db.Date
  notes                 String?   @db.Text
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@unique([provider, model, effectiveFromDate])
  @@index([provider, model, effectiveFromDate(sort: Desc)])
  @@map("model_pricing")
}

/// Per-tenant USD cost guardrail for AI spend. INDEPENDENT of the plan/
/// billing quota system (which counts feature uses) — this caps actual
/// inference dollars to protect margin and stop a runaway agent. Both fire:
/// quota first (cheap counter), then this cost budget.
///
/// Soft cap → call proceeds, UI shows a banner. Hard cap → the call is
/// blocked and the surface falls back (see AiTelemetryService.assertBudget +
/// per-surface handlers). Defaults are deliberately LOW so the mechanism
/// fires in staging and we can trust it before raising caps per tenant.
model TenantAiBudget {
  id       Int    @id @default(autoincrement())
  tenantId Int    @unique @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  dailySoftUsd   Decimal @default(5)   @map("daily_soft_usd")   @db.Decimal(10, 2)
  dailyHardUsd   Decimal @default(20)  @map("daily_hard_usd")   @db.Decimal(10, 2)
  monthlySoftUsd Decimal @default(50)  @map("monthly_soft_usd") @db.Decimal(10, 2)
  monthlyHardUsd Decimal @default(200) @map("monthly_hard_usd") @db.Decimal(10, 2)

  notes String? @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("tenant_ai_budgets")
}
