  userId    Int      @map("user_id")
  tenantId  Int      @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user   User   @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([tenantId])
  @@map("route_plan_feedback")
}

model Stop {
  id           Int          @id @default(autoincrement())
  stopId       String       @unique @map("stop_id") @db.VarChar(50)
  name         String       @db.VarChar(200)
  address      String?      @db.Text
  city         String?      @db.VarChar(100)
  state        String?      @db.VarChar(50)
  lat          Float?
  lon          Float?
  locationType LocationType @default(WAREHOUSE) @map("location_type")
  isActive     Boolean      @default(true) @map("is_active")

  // Geocode precision — drives import merge-suggestion tiering (rooftop vs city/ZIP centroid).
  locationPrecision LocationPrecision @default(UNKNOWN) @map("location_precision")

  // Non-binding "looks like this known facility" merge offer set by StopMatchService.
  suggestedMergeStopId Int?   @map("suggested_merge_stop_id")
  suggestedMergeStop   Stop?  @relation("StopMergeSuggestion", fields: [suggestedMergeStopId], references: [id])
  mergeSuggestedFor    Stop[] @relation("StopMergeSuggestion")

  zipCode  String? @map("zip_code") @db.VarChar(10)
  timezone String? @db.VarChar(50)

  // Fuel station fields
  fuelPricePerGallon Float?    @map("fuel_price_per_gallon")
  fuelPriceUpdatedAt DateTime? @map("fuel_price_updated_at") @db.Timestamptz
  fuelBrand          String?   @map("fuel_brand") @db.VarChar(50)

  // Truck stop fields
  amenities     Json? @db.JsonB
  parkingSpaces Int?  @map("parking_spaces")

  // Multi-tenancy (optional)
  tenantId Int? @map("tenant_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  loadStops          LoadStop[]
  routeSegments      RouteSegment[]
  recurringLaneStops RecurringLaneStop[]

  updatedAt           DateTime?       @updatedAt @map("updated_at") @db.Timestamptz
  contactName         String?         @map("contact_name") @db.VarChar(200)
  contactPhone        String?         @map("contact_phone") @db.VarChar(30)
  contactEmail        String?         @map("contact_email") @db.VarChar(200)
  operatingHours      Json?           @map("operating_hours") @db.JsonB
  appointmentRequired Boolean         @default(false) @map("appointment_required")
  // How the facility admits trucks vs its window (drives where the early-wait happens).
  entryPolicy         StopEntryPolicy @default(FCFS) @map("entry_policy")
  notes               String?         @db.Text

  @@index([tenantId])
  @@index([tenantId, lat, lon])
  @@map("stops")
}

model FuelCardType {
  id          String   @id @db.VarChar(20) // "OTR", "WEX", "EFS", "COMDATA", "EDGE"
  displayName String   @map("display_name") @db.VarChar(100)
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  brandAcceptance BrandFuelCardAcceptance[]

  @@map("fuel_card_types")
}

model BrandFuelCardAcceptance {
  id             Int          @id @default(autoincrement())
  brand          String       @db.VarChar(100)
  fuelCardTypeId String       @map("fuel_card_type_id") @db.VarChar(20)
  fuelCardType   FuelCardType @relation(fields: [fuelCardTypeId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz

  @@unique([brand, fuelCardTypeId])
  @@map("brand_fuel_card_acceptance")
}

model Customer {
  id                     Int            @id @default(autoincrement())
  customerId             String         @unique @map("customer_id") @db.VarChar(50)
  companyName            String         @map("company_name") @db.VarChar(200)
  customerType           CustomerType   @default(SHIPPER) @map("customer_type")
  status                 CustomerStatus @default(ACTIVE) @map("status")
  // Median (p50) detention beyond scheduled dock time, minutes, from this customer's
  // history. The planner adds it to dock dwell so the next stop's ETA is realistic.
  avgDetentionMinutesP50 Int?           @map("avg_detention_minutes_p50")
  deactivatedAt          DateTime?      @map("deactivated_at") @db.Timestamptz
  deactivatedBy          Int?           @map("deactivated_by")
  deactivatedByUser      User?          @relation("CustomerDeactivatedBy", fields: [deactivatedBy], references: [id])
  deactivationReason     String?        @map("deactivation_reason")
  reactivatedAt          DateTime?      @map("reactivated_at") @db.Timestamptz
  reactivatedBy          Int?           @map("reactivated_by")
  reactivatedByUser      User?          @relation("CustomerReactivatedBy", fields: [reactivatedBy], references: [id])

  // Identification
  mcNumber  String? @map("mc_number") @db.VarChar(20)
  dotNumber String? @map("dot_number") @db.VarChar(20)
  taxId     String? @map("tax_id") @db.VarChar(20)

  // Company address
  address String? @db.VarChar(500)
  city    String? @db.VarChar(100)
  state   String? @db.VarChar(50)

  // Financial
  paymentTerms              PaymentTerms?     @map("payment_terms")
  creditLimit               Decimal?          @map("credit_limit") @db.Decimal(12, 2)
  billingEmail              String?           @map("billing_email") @db.VarChar(255)
  billingAddress            String?           @map("billing_address") @db.VarChar(500)
  billingCity               String?           @map("billing_city") @db.VarChar(100)
  billingState              String?           @map("billing_state") @db.VarChar(50)
  billingZip                String?           @map("billing_zip") @db.VarChar(20)
  zipCode                   String?           @map("zip_code") @db.VarChar(10)
  website                   String?           @db.VarChar(500)
  defaultBillingPath        BillingPath?      @map("default_billing_path")
  defaultFactoringCompanyId Int?              @map("default_factoring_company_id")
  defaultFactoringCompany   FactoringCompany? @relation(fields: [defaultFactoringCompanyId], references: [id])

  // Internal
  notes             String? @db.Text
  notificationPrefs Json?   @map("notification_prefs") @db.JsonB

  // Custom fields (tenant-defined, JSONB)
  customFieldValues Json? @default("{}") @map("custom_field_values") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenantId Int    @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  loads           Load[]
  users           User[]
  invitations     UserInvitation[]
  invoices        Invoice[]
  contacts        CustomerContact[]
  noaRecords      NoaRecord[]
  laneRateHistory LaneRateHistory[]

  @@index([tenantId])
  @@map("customers")
}

model CustomerContact {
  id        Int           @id @default(autoincrement())
  contactId String        @unique @map("contact_id") @db.VarChar(50)
  firstName String        @map("first_name") @db.VarChar(100)
  lastName  String        @map("last_name") @db.VarChar(100)
  email     String?       @db.VarChar(255)
  phone     String?       @db.VarChar(20)
  role      ContactRole   @default(PRIMARY)
  isPrimary Boolean       @default(false) @map("is_primary")
  title     String?       @db.VarChar(100)
  notes     String?       @db.Text
  status    ContactStatus @default(ACTIVE)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  customerId Int      @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id])

  tenantId Int    @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([customerId, email])
  @@index([customerId])
  @@index([tenantId])
  @@map("customer_contacts")
}

enum LoadBillingStatus {
  PENDING_DOCUMENTS
  READY_FOR_REVIEW
  APPROVED
  INVOICED
  CLOSED
}

enum LoadStatus {
  TENDER
  DRAFT
  PENDING
  ASSIGNED
  IN_TRANSIT
  ON_HOLD
  DELIVERED
  CANCELLED
  TONU
}

enum LoadStopStatus {
  PENDING
  ARRIVED
  IN_PROGRESS
  COMPLETED
}

enum LoadLegStatus {
  PENDING
  ASSIGNED
  IN_TRANSIT
  ON_HOLD
  DELIVERED
  CANCELLED
}

model Load {
  id                  Int        @id @default(autoincrement())
  loadNumber          String     @map("load_number") @db.VarChar(50)
  status              LoadStatus @default(PENDING)
  weightLbs           Float      @map("weight_lbs")
  commodityType       String     @map("commodity_type") @db.VarChar(100)
  specialRequirements String?    @map("special_requirements") @db.Text
  customerName        String     @map("customer_name") @db.VarChar(200)

  // Customer reference / PO number
  referenceNumber String? @map("reference_number") @db.VarChar(100)

  // Rate / revenue for this load (stored in cents)
  rateCents Int? @map("rate_cents")

  // Billing lifecycle status (null = not delivered yet)
  billingStatus LoadBillingStatus? @map("billing_status")

  // Pieces / pallets count
  pieces Int?

  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deliveredAt DateTime? @map("delivered_at") @db.Timestamptz

  // Intake source tracking
  intakeSource   String @default("manual") @map("intake_source") @db.VarChar(30)
  intakeMetadata Json?  @map("intake_metadata") @db.JsonB

  // Custom fields (tenant-defined, JSONB)
  customFieldValues Json? @default("{}") @map("custom_field_values") @db.JsonB

  // Customer entity link
  customerId Int      @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id])

  // Required equipment type
  requiredEquipmentType EquipmentType? @map("required_equipment_type")

  // Driver, vehicle, and trailer assignment
  driverId  Int?     @map("driver_id")
  vehicleId Int?     @map("vehicle_id")
  trailerId Int?     @map("trailer_id")
  driver    Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  trailer   Trailer? @relation(fields: [trailerId], references: [id], onDelete: SetNull)

  // Trip grouping
  tripId    Int?    @map("trip_id")
  tripOrder Int?    @map("trip_order")
  trip      Trip?   @relation(fields: [tripId], references: [id], onDelete: SetNull)

  // External system linkage (for integration sync)
  externalLoadId String?            @map("external_load_id") @db.VarChar(100)
  externalSource IntegrationVendor? @map("external_source")
  lastSyncedAt   DateTime?          @map("last_synced_at") @db.Timestamptz

  // Denormalized display fields (auto-computed from stops)
  pickupDate       DateTime? @map("pickup_date") @db.Date
  deliveryDate     DateTime? @map("delivery_date") @db.Date
  originCity       String?   @map("origin_city") @db.VarChar(100)
  originState      String?   @map("origin_state") @db.VarChar(2)
  destinationCity  String?   @map("destination_city") @db.VarChar(100)
  destinationState String?   @map("destination_state") @db.VarChar(2)
  estimatedMiles   Float?    @map("estimated_miles")
  actualMiles      Float?    @map("actual_miles")

  // System-computed mileage (HERE Routing v8 truck mode). Written async by the
  // load-mileage queue. DO NOT auto-overwrite estimatedMiles/actualMiles — those
  // feed Settlements driver pay; totalMiles is system truth shown for reconciliation.
  totalMiles          Float?    @map("total_miles")
  estimatedDriveHours Float?    @map("estimated_drive_hours")
  mileageProvider     String?   @map("mileage_provider") @db.VarChar(20)
  mileageCalculatedAt DateTime? @map("mileage_calculated_at") @db.Timestamptz

  // Lifecycle timestamps
  assignedAt   DateTime? @map("assigned_at") @db.Timestamptz
  inTransitAt  DateTime? @map("in_transit_at") @db.Timestamptz
  cancelledAt  DateTime? @map("cancelled_at") @db.Timestamptz
  onHoldAt     DateTime? @map("on_hold_at") @db.Timestamptz
  onHoldReason String?   @map("on_hold_reason") @db.Text
  tonuAt       DateTime? @map("tonu_at") @db.Timestamptz
  tonuReason   String?   @map("tonu_reason") @db.Text

  // Temperature requirements (reefer loads)
  minTempF Float? @map("min_temp_f")
  maxTempF Float? @map("max_temp_f")

  // Hazmat
  hazmatClass     String?  @map("hazmat_class") @db.VarChar(20)
  unNumber        String?  @map("un_number") @db.VarChar(20)
  placardRequired Boolean? @map("placard_required")

  // EDI Tender fields
  ediTenderId       Int?               @unique @map("edi_tender_id")
  ediTenderMessage  EDIMessage?        @relation("LoadEdiTender", fields: [ediTenderId], references: [id])
  tenderExpiresAt   DateTime?          @map("tender_expires_at") @db.Timestamptz
  tenderRespondedAt DateTime?          @map("tender_responded_at") @db.Timestamptz
  tenderResponse    EDITenderResponse? @map("tender_response")

  // Recurring lane reference
  recurringLaneId Int?           @map("recurring_lane_id")
  recurringLane   RecurringLane? @relation(fields: [recurringLaneId], references: [id])

  tenantId            Int                  @map("tenant_id")
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  stops               LoadStop[]
  routePlanLoads      RoutePlanLoad[]
  invoices            Invoice[]
  settlementLineItems SettlementLineItem[]
  charges             LoadCharge[]
  events              LoadEvent[]
  notes               LoadNote[]
  billingOverrides    BillingOverride[]
  ediMessages         EDIMessage[]

  // Relay load support
  isRelay              Boolean               @default(false) @map("is_relay")
  legs                 LoadLeg[]
  moneyCodes           MoneyCode[]
  driverActionRequests DriverActionRequest[]
  laneRateHistory      LaneRateHistory[]
  shareLinks           LoadShareLink[]
  alerts               Alert[]
  conversationMessages ConversationMessage[]

  @@unique([loadNumber, tenantId])
  @@unique([externalLoadId, tenantId])
  @@index([tenantId])
  @@index([status])
  @@index([customerId])
  @@index([deliveredAt])
  @@index([billingStatus])
  @@index([cancelledAt])
  @@index([pickupDate])
  @@index([referenceNumber])
  @@index([tripId])
  @@index([driverId])
  @@index([vehicleId])
  @@map("loads")
}

model LoadShareLink {
  id           Int       @id @default(autoincrement())
  loadId       Int       @map("load_id")
  load         Load      @relation(fields: [loadId], references: [id], onDelete: Cascade)
  tenantId     Int       @map("tenant_id")
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  token        String    @unique @db.VarChar(32)
  recipient    String?   @db.VarChar(200)
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz
  revokedBy    Int?      @map("revoked_by")
  lastViewedAt DateTime? @map("last_viewed_at") @db.Timestamptz
  viewCount    Int       @default(0) @map("view_count")
  createdBy    Int       @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([loadId])
  @@index([token])
  @@index([tenantId, createdAt])
  @@map("load_share_links")
}

model Trip {
  id       Int    @id @default(autoincrement())
  tripId   String @unique @map("trip_id") @db.VarChar(30)
  tenantId Int    @map("tenant_id")

  driverId  Int? @map("driver_id")
  vehicleId Int? @map("vehicle_id")

  status TripStatus @default(DRAFT)

  loadCount         Int    @default(0) @map("load_count")
  totalMiles        Float? @map("total_miles")
  totalRevenueCents Int?   @map("total_revenue_cents")

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy   Int       @map("created_by")
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  assignedAt  DateTime? @map("assigned_at") @db.Timestamptz
  startedAt   DateTime? @map("started_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  cancelledAt DateTime? @map("cancelled_at") @db.Timestamptz

  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  driver        Driver?     @relation(fields: [driverId], references: [id])
  vehicle       Vehicle?    @relation(fields: [vehicleId], references: [id])
  loads         Load[]
  routePlans    RoutePlan[]
  createdByUser User        @relation("TripCreatedBy", fields: [createdBy], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, driverId])
  @@map("trips")
}

model LoadStop {
  id            Int    @id @default(autoincrement())
  loadId        Int    @map("load_id")
  stopId        Int    @map("stop_id")
  sequenceOrder Int    @map("sequence_order")
  actionType    String @map("action_type") @db.VarChar(20)

  // Scheduling
  appointmentDate    DateTime? @map("appointment_date") @db.Date
  earliestArrival    String?   @map("earliest_arrival") @db.VarChar(30)
  latestArrival      String?   @map("latest_arrival") @db.VarChar(30)
  estimatedDockHours Float     @map("estimated_dock_hours")
  actualDockHours    Float?    @map("actual_dock_hours")

  // Set on import when the location is known but the specific facility/dock is not
  // (no street address or no facility name). Drives the "Verify facility" review chip.
  facilityUnverified Boolean @default(false) @map("facility_unverified")

  // System-computed leg mileage to the next stop (HERE Routing). Async-written
  // by the load-mileage queue alongside Load.totalMiles.
  legMilesToNext      Float? @map("leg_miles_to_next")
  legDriveHoursToNext Float? @map("leg_drive_hours_to_next")

  // Stop Status & Timestamps
  status             LoadStopStatus @default(PENDING)
  arrivedAt          DateTime?      @map("arrived_at") @db.Timestamptz
  dockInAt           DateTime?      @map("dock_in_at") @db.Timestamptz
  loadingStartedAt   DateTime?      @map("loading_started_at") @db.Timestamptz
  loadingCompletedAt DateTime?      @map("loading_completed_at") @db.Timestamptz
  departedAt         DateTime?      @map("departed_at") @db.Timestamptz
  completedAt        DateTime?      @map("completed_at") @db.Timestamptz

  // Dock & Facility Info
  dockNumber           String? @map("dock_number") @db.VarChar(20)
  facilityContactName  String? @map("facility_contact_name") @db.VarChar(100)
  facilityContactPhone String? @map("facility_contact_phone") @db.VarChar(20)
  facilityNotes        String? @map("facility_notes") @db.Text

  // Driver & Dispatcher Notes
  driverNotes     String? @map("driver_notes") @db.Text
  dispatcherNotes String? @map("dispatcher_notes") @db.Text

  // BOL (Bill of Lading)
  bolNumber   String? @map("bol_number") @db.VarChar(50)
  bolImageUrl String? @map("bol_image_url") @db.VarChar(500)
  sealNumber  String? @map("seal_number") @db.VarChar(50)

  // Proof of Delivery (POD)
  podSignatureUrl String?   @map("pod_signature_url") @db.VarChar(500)
  podSignedBy     String?   @map("pod_signed_by") @db.VarChar(100)
  podSignedAt     DateTime? @map("pod_signed_at") @db.Timestamptz
  podNotes        String?   @map("pod_notes") @db.Text
  podPhotos       Json?     @map("pod_photos") @db.JsonB

  // Weight & Counts
  actualWeight  Float? @map("actual_weight")
  actualPieces  Int?   @map("actual_pieces")
  shortPieces   Int?   @map("short_pieces")
  damagedPieces Int?   @map("damaged_pieces")
  overPieces    Int?   @map("over_pieces")

  // Detention & Accessorials
  detentionStartedAt DateTime? @map("detention_started_at") @db.Timestamptz
  detentionMinutes   Int?      @map("detention_minutes")
  accessorials       Json?     @map("accessorials") @db.JsonB

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  load Load @relation(fields: [loadId], references: [id], onDelete: Cascade)
  stop Stop @relation(fields: [stopId], references: [id])

  // Relay leg boundaries
  legOrigins           LoadLeg[]             @relation("LegOrigin")
  legDests             LoadLeg[]             @relation("LegDest")
  moneyCodes           MoneyCode[]
  driverActionRequests DriverActionRequest[]

  @@index([loadId])
  @@index([status])
  @@index([stopId])
  @@map("load_stops")
}

model RoutePlanLoad {
  id        Int      @id @default(autoincrement())
  planId    Int      @map("plan_id")
  loadId    Int      @map("load_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  plan RoutePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  load Load      @relation(fields: [loadId], references: [id])

  @@unique([planId, loadId])
  @@index([planId])
  @@index([loadId])
  @@map("route_plan_loads")
}

model LoadEvent {
  id          Int      @id @default(autoincrement())
  loadId      Int      @map("load_id")
  eventType   String   @db.VarChar(50)
  fromValue   String?  @db.Text
  toValue     String?  @db.Text
  description String?  @db.Text
  userId      Int?     @map("user_id")
  metadata    Json?    @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  load Load @relation(fields: [loadId], references: [id], onDelete: Cascade)

  @@index([loadId])
  @@index([eventType])
  @@map("load_events")
}

model LoadLeg {
  id       Int           @id @default(autoincrement())
  legId    String        @unique @map("leg_id") @db.VarChar(50)
  sequence Int
  status   LoadLegStatus @default(PENDING)

  // Driver, Vehicle & Trailer (nullable until assigned)
  driverId  Int?     @map("driver_id")
  vehicleId Int?     @map("vehicle_id")
  trailerId Int?     @map("trailer_id")
  driver    Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  trailer   Trailer? @relation(fields: [trailerId], references: [id], onDelete: SetNull)

  // Stop boundaries (which stops this leg covers)
  originStopId Int      @map("origin_stop_id")
  destStopId   Int      @map("dest_stop_id")
  originStop   LoadStop @relation("LegOrigin", fields: [originStopId], references: [id])
  destStop     LoadStop @relation("LegDest", fields: [destStopId], references: [id])

  // Mileage
  actualMiles Float? @map("actual_miles")

  // Lifecycle timestamps
  assignedAt  DateTime? @map("assigned_at") @db.Timestamptz
  pickedUpAt  DateTime? @map("picked_up_at") @db.Timestamptz
  deliveredAt DateTime? @map("delivered_at") @db.Timestamptz

  // Route plan link (one plan per leg, nullable)
  routePlanId Int?       @unique @map("route_plan_id")
  routePlan   RoutePlan? @relation(fields: [routePlanId], references: [id], onDelete: SetNull)

  // Load parent
  loadId Int  @map("load_id")
  load   Load @relation(fields: [loadId], references: [id], onDelete: Cascade)

  // Tenant
  tenantId Int    @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // Settlement line items
  settlementLineItems SettlementLineItem[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([loadId, sequence])
  @@index([loadId])
  @@index([driverId])
  @@index([tenantId, status])
  @@map("load_legs")
}

model LoadCharge {
  id             Int      @id @default(autoincrement())
  loadId         Int      @map("load_id")
  chargeType     String   @db.VarChar(50)
