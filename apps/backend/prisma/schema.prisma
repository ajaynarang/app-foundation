  lon Float? @map("lon")

  replanRecommended Boolean @default(false) @map("replan_recommended")
  replanReason      String? @map("replan_reason") @db.Text

  impactSummary Json? @map("impact_summary") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  plan RoutePlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([planId, segmentId])
  @@index([eventType])
  @@map("route_events")
