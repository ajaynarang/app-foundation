  medicalCardExpiry     DateTime? @map("medical_card_expiry") @db.Date
  cdlExpiry             DateTime? @map("cdl_expiry") @db.Date
  mvrDate               DateTime? @map("mvr_date") @db.Date
  drugTestDate          DateTime? @map("drug_test_date") @db.Date
  annualReviewDate      DateTime? @map("annual_review_date") @db.Date
  emergencyContactName  String?   @map("emergency_contact_name") @db.VarChar(255)
  emergencyContactPhone String?   @map("emergency_contact_phone") @db.VarChar(20)
  notes                 String?   @db.Text

  // Custom fields (tenant-defined, JSONB)
  customFieldValues Json? @default("{}") @map("custom_field_values") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Primary vehicle assignment (1:1 bidirectional with Vehicle)
  assignedVehicleId Int?     @unique @map("assigned_vehicle_id")
  assignedVehicle   Vehicle? @relation("PrimaryVehicle", fields: [assignedVehicleId], references: [id])
  primaryForVehicle Vehicle? @relation("PrimaryDriver")

  // Relations
  user                 User?
  routePlans           RoutePlan[]
  loads                Load[]
  driverPreferences    DriverPreferences?
  invitations          UserInvitation[]
  payStructures        DriverPayStructure[]
  settlements          Settlement[]
  dvirs                VehicleDVIR[]
  trailerDvirs         TrailerDVIR[]
  iftaFuelPurchases    IftaFuelPurchase[]
  loadLegs             LoadLeg[]
  moneyCodes           MoneyCode[]
  driverActionRequests DriverActionRequest[]
  unavailabilities     DriverUnavailability[]
  trips                Trip[]
