// ============================================================================
// SALLY'S DESK — Agentic runtime (Temporal-backed)
//
// Architecture: .docs/plans/06-sally-ai/2026-04-20-desk-architecture-v3.md
//
// Layers:
//   • DeskAgent            — 12 AI personas
//   • DeskResponsibility   — per-tenant config (trust, conditions, notes)
//   • DeskEpisode          — one run against one entity; durable
//   • DeskEpisodeStep      — atomic audit row (hydrate/perceive/decide/draft/gate/execute/close)
//   • DeskApproval         — human decisions on gated steps
//   • DeskMemory           — agent-scoped long-term learning (pgvector)
//
// Execution state lives in Temporal Cloud (linked via temporal_workflow_id).
// These tables own config + audit only.
// ============================================================================

enum TrustLevel {
  SUPERVISED
  ASSISTED
  AUTONOMOUS
}

enum Lifecycle {
  AVAILABLE
  COMING_SOON
}

enum TriggerKind {
  SCHEDULED
  DOMAIN_EVENT
  WEBHOOK
  MANUAL
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ApprovalDecision {
  APPROVED
  EDITED
  REJECTED
}

enum DeskEpisodeStatus {
  RUNNING
  WAITING_APPROVAL
  RESOLVED
  ESCALATED
  FAILED
  REJECTED_BY_OPERATOR
  CANCELLED
  EXPIRED
}

enum DeskEpisodeStepKind {
  HYDRATE
  PERCEIVE
  DECIDE
  DRAFT
  GATE
  EXECUTE
  CLOSE
}

enum DeskEpisodeStepStatus {
  RUNNING
  SUCCEEDED
  FAILED
  GATED
  SKIPPED
}

model DeskAgent {
  id               Int      @id @default(autoincrement())
  tenantId         Int      @map("tenant_id")
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key              String   @db.VarChar(40)
  name             String   @db.VarChar(80)
  description      String?  @map("description") @db.Text
  systemPromptKey  String   @map("system_prompt_key") @db.VarChar(120)
  isActive         Boolean  @default(true) @map("is_active")
  supervisorUserId Int?     @map("supervisor_user_id")
  supervisor       User?    @relation("DeskAgentSupervisor", fields: [supervisorUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  responsibilities DeskResponsibility[]
  episodes         DeskEpisode[]
  steps            DeskEpisodeStep[]
  memories         DeskMemory[]

  @@unique([tenantId, key])
  @@index([supervisorUserId])
  @@map("desk_agents")
}

model DeskResponsibility {
  id       Int       @id @default(autoincrement())
  tenantId Int       @map("tenant_id")
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId  Int       @map("agent_id")
  agent    DeskAgent @relation(fields: [agentId], references: [id])

  key         String    @db.VarChar(60)
  title       String    @db.VarChar(160)
  description String?   @db.Text
  lifecycle   Lifecycle @default(COMING_SOON)
  enabled     Boolean   @default(true)

  // Autonomy switch: when true (and the tenant master switch is on), this
  // responsibility may run on its OWN — any non-manual trigger (scheduled
  // today; domain-event / webhook in the future). Default FALSE — a new
  // responsibility never runs on its own until an operator opts in; testing
  // happens via the manual "Run now" trigger, which ignores this flag.
  autonomyEnabled Boolean @default(false) @map("autonomy_enabled")

  // User-editable policy (UI settings page)
  trustLevel TrustLevel @default(SUPERVISED) @map("trust_level")
  conditions Json       @default("{}") @db.JsonB // typed per-responsibility
  // notesForSally retired — operator free-form rules now live as
  // operator-authored playbook memories (DeskMemory.scope='PLAYBOOK',
  // authoredByUserId IS NOT NULL). Existing column values backfilled by
  // the same migration that drops the column.

  lastRunAt DateTime? @map("last_run_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  episodes DeskEpisode[]

  @@unique([tenantId, key])
  @@index([tenantId, enabled, lifecycle])
  @@map("desk_responsibilities")
}

/// Per-(tenant, job) idempotency stamp for tenant-local time-of-day jobs
/// (e.g. the alert digest and Shield audit). The hourly heartbeat records the
/// tenant-local date a job last fired for that tenant, so a later tick or retry
/// the same local day is a no-op. Keyed by (tenantId, jobKey) so a new
/// time-of-day job is a new `jobKey` value (data), not a new column on Tenant.
model TenantJobRun {
  id       Int    @id @default(autoincrement())
  tenantId Int    @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  jobKey      String   @map("job_key") @db.VarChar(60)
  lastRunDate DateTime @map("last_run_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, jobKey])
  @@index([tenantId])
  @@map("tenant_job_runs")
}

model DeskEpisode {
  /// UUIDv7, generated via generateUuidV7() in shared/utils/uuidv7.ts.
  /// See id-convention.md Rule 2 (audit / event / log PKs).
  id       String @id @db.Uuid
  tenantId Int    @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  responsibilityId Int                @map("responsibility_id")
  responsibility   DeskResponsibility @relation(fields: [responsibilityId], references: [id])
  ownerAgentId     Int                @map("owner_agent_id")
  ownerAgent       DeskAgent          @relation(fields: [ownerAgentId], references: [id])

  // Snapshots — frozen at open; mid-flight admin edits don't apply retroactively
  trustLevelSnapshot TrustLevel @map("trust_level_snapshot")
  conditionsSnapshot Json       @map("conditions_snapshot") @db.JsonB

  // Trigger metadata
  triggerKind    TriggerKind @map("trigger_kind")
  triggerLabel   String      @map("trigger_label") @db.VarChar(160)
  triggerSource  String?     @map("trigger_source") @db.VarChar(160)
  triggerFiredAt DateTime    @map("trigger_fired_at") @db.Timestamptz
  triggerPayload Json?       @map("trigger_payload") @db.JsonB

  // Entity
  entityType  String? @map("entity_type") @db.VarChar(40)
  entityId    String? @map("entity_id") @db.VarChar(120)
  entityLabel String? @map("entity_label") @db.VarChar(200)

  // State
  status    DeskEpisodeStatus
  priority  Priority          @default(NORMAL)
  dedupeKey String            @map("dedupe_key") @db.VarChar(200)

  // Outcome (set by close step)
  outcome     String? @db.VarChar(40)
  outcomeNote String? @map("outcome_note") @db.Text

  // Temporal linkage — Temporal Cloud owns execution state
  temporalWorkflowId String  @map("temporal_workflow_id") @db.VarChar(200)
  temporalRunId      String? @map("temporal_run_id") @db.VarChar(100)

  openedAt  DateTime  @default(now()) @map("opened_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  closedAt  DateTime? @map("closed_at") @db.Timestamptz
  expiresAt DateTime? @map("expires_at") @db.Timestamptz

  // Memory rows hydrate retrieved for this episode. Persisted at hydrate
  // time so the reinforcer (close.step) can walk the same set without
  // re-querying. Surfaced to the UI via DeskEpisodeDetail.
  retrievedMemoryIds String[] @default([]) @map("retrieved_memory_ids") @db.Uuid

  steps              DeskEpisodeStep[]
  approvals          DeskApproval[]
  entitySuppressions DeskEntitySuppression[]

  // NOTE: (tenant_id, dedupe_key) uniqueness enforced by partial unique index
  // created in raw SQL (migration adds WHERE status IN ('RUNNING','WAITING_APPROVAL')).
  // Prisma cannot express the WHERE clause.
  @@index([tenantId, dedupeKey])
  @@index([tenantId, status, priority])
  @@index([tenantId, responsibilityId, status])
  @@index([entityType, entityId])
  @@index([temporalWorkflowId])
  @@map("desk_episodes")
}

model DeskEpisodeStep {
  /// UUIDv7, generated via generateUuidV7() in shared/utils/uuidv7.ts.
  /// See id-convention.md Rule 2 (audit / event / log PKs).
  id        String      @id @db.Uuid
  episodeId String      @map("episode_id") @db.Uuid
  episode   DeskEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  agentId Int?       @map("agent_id") // null for non-LLM steps
  agent   DeskAgent? @relation(fields: [agentId], references: [id])

  sequence Int // monotonic insertion order
  kind     DeskEpisodeStepKind
  status   DeskEpisodeStepStatus

  // LLM metadata (null for non-LLM steps).
  model     String? @db.VarChar(20)
  promptKey String? @map("prompt_key") @db.VarChar(120)

  /// Foreign key into the AiInvocation ledger — the single source of truth
  /// for this step's token counts + USD cost. Join here for cost-per-step
  /// (vw_ai_cost_per_episode does exactly that). The legacy inline
  /// tokens_input/tokens_output/cost_usd columns were dropped in PR 12 once
  /// every Desk LLM step routed through AiTelemetryService.
  aiInvocationId String?       @map("ai_invocation_id") @db.Uuid
  aiInvocation   AiInvocation? @relation(fields: [aiInvocationId], references: [id], onDelete: SetNull)

  // Tool metadata (for execute + hydrate steps)
  // Scope + tier are captured from Agent Contract ScopeRegistryService at
  // execute time — no separate tool-risk enum. `toolTier` derives from
  // scopeTier(toolScope) at write time; stored for audit queries.
  toolName   String? @map("tool_name") @db.VarChar(80)
  toolScope  String? @map("tool_scope") @db.VarChar(60)
  toolTier   String? @map("tool_tier") @db.VarChar(16)
  toolArgs   Json?   @map("tool_args") @db.JsonB
  toolResult Json?   @map("tool_result") @db.JsonB

  // Gate step metadata
  gateDecision Json? @map("gate_decision") @db.JsonB // { gated, rule, checks, approvalId? }

  // LLM voice output + confidence
  output       Json?   @db.JsonB
  confidence   Float?
  errorMessage String? @map("error_message") @db.Text

  durationMs Int?      @map("duration_ms")
  startedAt  DateTime  @default(now()) @map("started_at") @db.Timestamptz
  finishedAt DateTime? @map("finished_at") @db.Timestamptz

  approvals DeskApproval[]

  @@unique([episodeId, sequence])
  @@index([episodeId])
  @@index([toolName])
  @@index([aiInvocationId])
  @@map("desk_episode_steps")
}

model DeskApproval {
