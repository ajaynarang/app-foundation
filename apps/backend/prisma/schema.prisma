  insuranceExpiry      DateTime? @map("insurance_expiry") @db.Date
  annualInspectionDate DateTime? @map("annual_inspection_date") @db.Date
  nextMaintenanceDate  DateTime? @map("next_maintenance_date") @db.Date

  status             VehicleStatus          @default(AVAILABLE)
  lifecycleStatus    VehicleLifecycleStatus @default(ACTIVE) @map("lifecycle_status")
  previousStatus     VehicleStatus?         @map("previous_status")
  deactivatedAt      DateTime?              @map("deactivated_at") @db.Timestamptz
  deactivatedBy      Int?                   @map("deactivated_by")
  deactivatedByUser  User?                  @relation("VehicleDeactivatedBy", fields: [deactivatedBy], references: [id])
  deactivationReason String?                @map("deactivation_reason")
  reactivatedAt      DateTime?              @map("reactivated_at") @db.Timestamptz
  reactivatedBy      Int?                   @map("reactivated_by")
  reactivatedByUser  User?                  @relation("VehicleReactivatedBy", fields: [reactivatedBy], references: [id])
  equipmentType      EquipmentType          @map("equipment_type")
  ownershipType      OwnershipType?         @map("ownership_type")

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId Int    @map("tenant_id")

  // Primary driver assignment (1:1 bidirectional with Driver)
  assignedDriverId Int?    @unique @map("assigned_driver_id")
  assignedDriver   Driver? @relation("PrimaryDriver", fields: [assignedDriverId], references: [id])
  primaryForDriver Driver? @relation("PrimaryVehicle")

  currentTrailer    Trailer?                @relation("CurrentTrailer")
  routePlans        RoutePlan[]
  loads             Load[]
  telematics        VehicleTelematics?
  dvirs             VehicleDVIR[]
  iftaStateMileage  IftaStateMileage[]
  iftaFuelPurchases IftaFuelPurchase[]
  loadLegs          LoadLeg[]
  unavailabilities  VehicleUnavailability[]
  trips             Trip[]
  alerts            Alert[]

  @@unique([vehicleId, tenantId])
  @@unique([externalVehicleId, tenantId])
  @@unique([vin, tenantId])
  @@index([tenantId])
  @@index([vin])
  @@index([licensePlate])
  @@map("vehicles")
}

