// ============================================================================
// OAUTH 2.1 PROVIDER MODELS
// ============================================================================

/// OAuth 2.1 client application registered to access SALLY APIs.
model OAuthClient {
  id           Int     @id @default(autoincrement())
  clientId     String  @unique @map("client_id") @db.VarChar(64)
  clientSecret String  @map("client_secret") @db.VarChar(255)
  name         String  @db.VarChar(255)
  description  String? @db.Text

  redirectUris String[] @map("redirect_uris")
  scopes       String[]
  clientType   String   @default("confidential") @map("client_type") @db.VarChar(20)

  tenantId        Int?    @map("tenant_id")
  tenant          Tenant? @relation(fields: [tenantId], references: [id])
  createdByUserId Int?    @map("created_by_user_id")
  createdByUser   User?   @relation("OAuthClientCreator", fields: [createdByUserId], references: [id])

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  authorizationCodes OAuthAuthorizationCode[]
  accessTokens       OAuthAccessToken[]
  refreshTokens      OAuthRefreshToken[]

  @@index([tenantId])
  @@map("oauth_clients")
}

/// OAuth 2.1 authorization code — short-lived, single-use.
model OAuthAuthorizationCode {
  id   Int    @id @default(autoincrement())
  code String @unique @db.VarChar(128)

  clientId Int         @map("client_id")
  client   OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId   Int         @map("user_id")
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  codeChallenge       String @map("code_challenge") @db.VarChar(128)
  codeChallengeMethod String @default("S256") @map("code_challenge_method") @db.VarChar(10)

  scopes      String[]
  redirectUri String    @map("redirect_uri") @db.VarChar(2048)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz
  usedAt      DateTime? @map("used_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([code])
  @@index([expiresAt])
  @@map("oauth_authorization_codes")
}

/// OAuth 2.1 access token — stores hash for revocation checks.
model OAuthAccessToken {
  id        Int    @id @default(autoincrement())
  tokenHash String @unique @map("token_hash") @db.VarChar(128)

  clientId Int         @map("client_id")
  client   OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId   Int         @map("user_id")
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  scopes    String[]
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([tokenHash])
  @@index([userId])
  @@index([expiresAt])
  @@map("oauth_access_tokens")
}

/// OAuth 2.1 refresh token — long-lived, rotated on use.
model OAuthRefreshToken {
  id        Int    @id @default(autoincrement())
  tokenHash String @unique @map("token_hash") @db.VarChar(128)

  clientId Int         @map("client_id")
  client   OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId   Int         @map("user_id")
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  scopes           String[]
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz
  rotatedAt        DateTime? @map("rotated_at") @db.Timestamptz
  replacedByHash   String?   @map("replaced_by_hash") @db.VarChar(128)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  originalIssuedAt DateTime  @default(now()) @map("original_issued_at") @db.Timestamptz

  @@index([tokenHash])
  @@index([userId])
  @@index([expiresAt])
  @@map("oauth_refresh_tokens")
}

