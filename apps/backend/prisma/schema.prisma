// Phase 4 — factoring money ledger. Single source of truth for advance / reserve
// release / fee / chargeback / chargeback-reversal events. Denormalized fields
// on Invoice are a fast-read cache rebuilt from this ledger.
model FactoringTransaction {
  id            Int    @id @default(autoincrement())
  transactionId String @unique @map("transaction_id") @db.VarChar(50)

  invoiceId Int     @map("invoice_id")
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  factoringCompanyId Int              @map("factoring_company_id")
  factoringCompany   FactoringCompany @relation(fields: [factoringCompanyId], references: [id], onDelete: Restrict)

  type            FactoringTxnType
  amountCents     Int              @map("amount_cents")
  transactionDate DateTime         @map("transaction_date") @db.Date
  referenceNumber String?          @map("reference_number") @db.VarChar(100)
  notes           String?          @db.Text

  // Snapshot of the rate-card values at record time, so historical txns are
  // immune to mid-stream rate-card changes on FactoringCompany.
  advanceRatePctSnapshot Decimal? @map("advance_rate_pct_snapshot") @db.Decimal(5, 2)
  feeRatePctSnapshot     Decimal? @map("fee_rate_pct_snapshot") @db.Decimal(5, 2)

  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy Int?      @map("created_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  deletedBy Int?      @map("deleted_by")

  tenantId Int    @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  // Race protection: two dispatchers recording the same advance simultaneously.
  // P2002 surfaces as ConflictException with a clean toast message.
  @@unique([invoiceId, type, transactionDate, amountCents], name: "factoring_txn_dedup")
  @@index([invoiceId])
  @@index([tenantId, transactionDate])
  @@index([factoringCompanyId])
  @@index([tenantId, type])
  @@map("factoring_transactions")
}

