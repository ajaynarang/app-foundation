/// Permanent queue failures — when a BullMQ job exhausts its retries, the
/// processor persists the envelope + error here so the failure survives Bull's
/// 7-day `failed` set retention and can be replayed by an operator.
/// See queue-topology-redesign plan, Task 0.3.
model DeadLetterLog {
  /// App-generated UUIDv7 via generateUuidV7() — time-sortable PK. No
  /// Prisma @default; every create() must pass `id: generateUuidV7()`.
  id String @id @db.Uuid

  tenantId Int    @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  queueName String @map("queue_name") @db.VarChar(40)
  jobName   String @map("job_name") @db.VarChar(80)
  bullJobId String @map("bull_job_id") @db.VarChar(120)
  jobDbId   Int?   @map("job_db_id") // FK to Job table when present

  correlationId String? @map("correlation_id") @db.VarChar(120)
  causationId   String? @map("causation_id") @db.VarChar(120)

  payload      Json    @db.JsonB
  errorMessage String  @map("error_message") @db.Text
  errorStack   String? @map("error_stack") @db.Text
  attempts     Int

  failedAt    DateTime  @default(now()) @map("failed_at") @db.Timestamptz
  replayedAt  DateTime? @map("replayed_at") @db.Timestamptz
  replayedBy  String?   @map("replayed_by") @db.VarChar(120)
  replayJobId String?   @map("replay_job_id") @db.VarChar(120)

  @@index([tenantId, queueName, failedAt])
  @@index([bullJobId])
  @@map("dead_letter_logs")
}

