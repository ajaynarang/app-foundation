# ===========================================================
# Backend — Environment Variable Reference
# ===========================================================
# Copy to `.env` for local dev (or use Doppler/your secret manager).
# This file documents every variable the backend expects. Secrets are
# commented out — fill them in locally; never commit real values.
# ===========================================================


# --------------- Core ---------------
NODE_ENV=development
ENV_TYPE=development
LOG_LEVEL=DEBUG
PORT=8000

# --------------- Tenancy ---------------
# true  = multi-tenant (tenant resolution + self-registration enabled)
# false = single-tenant (one implicit tenant, registration disabled)
MULTI_TENANT=true
IMPLICIT_TENANT_ID=1
DEFAULT_ADMIN_EMAIL=owner@example.com

# --------------- Observability ---------------
# Start the stack: `docker compose --profile observability up -d`
# Then open Grafana at http://localhost:3003 (anonymous admin).
OTEL_SERVICE_NAME=app-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Pino logs — set LOG_TRANSPORT=loki to also ship to Loki.
LOG_TRANSPORT=
LOKI_URL=http://localhost:3100

# --------------- Database (Required) ---------------
# Matches docker-compose (postgres on host port 5499).
DATABASE_URL=postgresql://postgres:postgres@localhost:5499/app?schema=public

# --------------- Redis (Required) ---------------
REDIS_URL=redis://localhost:6399/0

# --------------- API Config ---------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_V1_PREFIX=/api/v1
PROJECT_NAME=App Backend
APP_URL=http://localhost:3000
CONSOLE_URL=http://localhost:3002

# --------------- Auth Cookies ---------------
# In prod (multi-tenant), set to apex domain (e.g. .example.com) so the refresh
# cookie is shared across subdomains. Blank in dev (localhost).
COOKIE_DOMAIN=

# --------------- JWT Config ---------------
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
# --- Secrets (required) ---
# SECRET_KEY=local-dev-secret-key-minimum-32-chars-here-change-me
# JWT_ACCESS_SECRET=local-jwt-access-secret-change-in-dev-min-32-chars
# JWT_REFRESH_SECRET=local-jwt-refresh-secret-change-in-dev-min-32-chars

# --------------- Authentication ---------------
BCRYPT_ROUNDS=10
# Dev-only: gates /api/v1/dev/* endpoints. Unset in prd (route 404s).
# DEV_AUTH_SECRET=random-32-char-string

# --------------- Credentials Encryption ---------------
# CREDENTIALS_ENCRYPTION_KEY=your-64-char-hex-key

# --------------- Firebase (Required for auth) ---------------
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# --------------- Tenant Subdomains (multi-tenant only) ---------------
TENANT_BASE_URL=localhost:3000
USE_TENANT_SUBDOMAINS=false

# --------------- Email ---------------
EMAIL_FROM=noreply@example.com
# Resend (transactional email provider)
# RESEND_API_KEY=re_your_resend_key
RESEND_INBOUND_WEBHOOK_SECRET=

# --------------- S3 Object Storage ---------------
S3_BUCKET=app-files
S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --------------- AI Provider ---------------
# AI_PROVIDER controls routing: 'anthropic' (direct SDK) or 'gateway' (Vercel AI Gateway)
AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-key
# AI_GATEWAY_API_KEY=your-gateway-key      # optional — needed for embeddings
# OPENAI_API_KEY=sk-your-openai-key        # optional — content moderation

# --------------- LangFuse (Optional — LLM observability + prompt management) ---------------
# Without these, LangFuse tracing is disabled (zero cost).
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
PROMPT_LABEL=production

# --------------- Phone Auth (dev only) ---------------
# Any OTP matching this value passes verification in dev
TWILIO_MOCK_OTP=123456
# --- Twilio (Optional — SMS invitations + real phone OTP) ---
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --------------- QuickBooks (sample integration vendor) ---------------
QUICKBOOKS_SANDBOX=true
# QUICKBOOKS_OAUTH_CLIENT_ID=your_client_id_here
# QUICKBOOKS_OAUTH_CLIENT_SECRET=your_client_secret_here
# QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN=your_verifier_token_here

# --------------- OAuth Integrations (Non-secret config) ---------------
# Shared callback URL for all OAuth vendors (one endpoint handles all)
OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/integrations/oauth/callback

# --------------- OAuth Provider (MCP Server Auth) ---------------
# Issuer URL for OAuth 2.1 server metadata (/.well-known/oauth-authorization-server)
OAUTH_ISSUER=http://localhost:8000

# --------------- Bull Board (Queue Admin UI) ---------------
# Dev bypass: BULL_BOARD_AUTH=false disables auth for /admin/queues
# In stg/prd leave 'true' so SUPER_ADMIN JWT is enforced
BULL_BOARD_AUTH=false

# --------------- Web Push Notifications ---------------
# Generate VAPID keys: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:support@example.com

# --------------- Stripe Billing ---------------
# Price IDs live in the database (PlanConfig.providerPriceId, AddOn.providerPriceId)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --------------- Cloudflare Turnstile (Optional — bot protection on registration) ---------------
# TURNSTILE_SECRET_KEY=

# --------------- Voice Mode (Optional — LiveKit + Deepgram + Cartesia) ---------------
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# DEEPGRAM_API_KEY=
# CARTESIA_API_KEY=
# VOICE_AGENT_SECRET= (auto-generated in dev if not set)
# Public origin the forked voice-agent worker calls back into
APP_API_URL=http://localhost:8000

# --------------- Inngest (Desk durable workflows) ---------------
# Local dev: leave EVENT_KEY and SIGNING_KEY empty — the Inngest CLI dev server
# (pnpm inngest:dev) handles auth locally.
INNGEST_ENV=dev
INNGEST_SERVE_ORIGIN=http://host.docker.internal:8000
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
