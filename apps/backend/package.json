{
  "name": "@app/backend",
  "version": "0.1.0",
  "description": "Platform Node.js/TypeScript Backend",
  "author": "Platform Team",
  "private": true,
  "license": "MIT",
  "scripts": {
    "// — App Lifecycle": "",
    "build": "nest build",
    "dev": "pnpm --filter shared-types build && prisma generate && NODE_OPTIONS='--max-old-space-size=4096' nest start --watch",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "// — Code Quality": "",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"prisma/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"prisma/**/*.ts\" \"scripts/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix && pnpm lint:schema",
    "lint:schema": "tsx scripts/lint-schema.ts",
    "// — Testing": "",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "// — Prisma": "",
    "prisma:generate": "prisma generate && tsx scripts/generate-shared-enums.ts",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:studio": "prisma studio",
    "// — Database (reset, push, cleanup)": "",
    "db:seed": "ts-node prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:push": "prisma db push",
    "// — Setup & Seeding": "",
    "setup:base": "ts-node prisma/seeds/index.ts",
    "setup:reset": "prisma migrate reset --force && ts-node prisma/seeds/index.ts",
    "setup:status": "ts-node prisma/seeds/index.ts --status",
    "// — AI Seeding (knowledge base, LLM prompts, model pricing)": "",
    "seed:knowledge": "ts-node src/domains/ai/knowledge-base/ingestion.command.ts",
    "seed:langfuse": "tsx scripts/seed-langfuse-prompts.ts",
    "seed:model-pricing": "tsx scripts/seed-model-pricing.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.44",
    "@ai-sdk/openai": "^3.0.52",
    "@aws-sdk/client-s3": "^3.995.0",
    "@aws-sdk/s3-request-presigner": "^3.995.0",
    "@bull-board/api": "^6.18.2",
    "@bull-board/express": "^6.18.2",
    "@bull-board/nestjs": "^6.18.2",
    "@here/flexpolyline": "^0.1.0",
    "@langfuse/otel": "^5.4.0",
    "@langfuse/tracing": "^5.4.0",
    "@livekit/agents": "^1.0.50",
    "@livekit/agents-plugin-cartesia": "^1.0.50",
    "@livekit/agents-plugin-deepgram": "^1.0.50",
    "@livekit/agents-plugin-silero": "^1.0.50",
    "@mastra/core": "^1.4.0",
    "@mastra/langfuse": "^1.0.3",
    "@mastra/mcp": "^1.0.1",
    "@mastra/memory": "^1.3.0",
    "@mastra/observability": "^1.2.1",
    "@mastra/pg": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "11.2.5",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@opentelemetry/auto-instrumentations-node": "^0.70.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@presidio-dev/hai-guardrails": "^1.12.0",
    "@prisma/adapter-pg": "7.3.0",
    "@prisma/client": "7.3.0",
    "@rekog/mcp-nest": "^1.9.4",
    "@app/shared-types": "workspace:*",
    "@types/nodemailer": "7.0.9",
    "ai": "^6.0.86",
    "archiver": "^7.0.1",
    "axios": "1.13.4",
    "bcrypt": "6.0.0",
    "bullmq": "^5.69.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.3",
    "cookie-parser": "1.4.7",
    "cron-parser": "^5.5.0",
    "date-fns": "^4.1.0",
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "firebase-admin": "13.6.0",
    "gray-matter": "^4.0.3",
    "helmet": "^8.1.0",
    "inngest": "^4.2.4",
    "ioredis": "5.9.2",
    "langfuse": "^3.38.6",
    "libphonenumber-js": "^1.12.38",
    "livekit-server-sdk": "^2.15.0",
    "luxon": "^3.7.2",
    "nanoid": "3.3.11",
    "nestjs-pino": "4.5.0",
    "nestjs-zod": "5.1.1",
    "nodemailer": "7.0.13",
    "openai": "^6.22.0",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfmake": "^0.3.5",
    "pg": "8.17.2",
    "pino": "10.3.0",
    "pino-loki": "^3.0.0",
    "pino-pretty": "13.1.3",
    "redact-pii": "^3.4.0",
    "reflect-metadata": "^0.2.2",
    "resend": "6.9.1",
    "rxjs": "^7.8.1",
    "stripe": "^17.7.0",
    "twilio": "^5.12.1",
    "ua-parser-js": "^2.0.10",
    "uuid": "11.1.1",
    "web-push": "^3.6.7",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@isaacs/brace-expansion": "^5.0.1",
    "@nestjs/cli": "11.0.16",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "11.1.12",
    "@types/archiver": "^7.0.0",
    "@types/bcrypt": "6.0.0",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/multer": "^2.0.0",
    "@types/node": "22.19.7",
    "@types/passport-jwt": "4.0.1",
    "@types/pdfmake": "^0.3.1",
    "@types/pg": "8.16.0",
    "@types/seedrandom": "^3.0.8",
    "@types/supertest": "6.0.3",
    "@types/uuid": "10.0.0",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "30.2.0",
    "prettier": "^3.4.2",
    "prisma": "7.3.0",
    "seedrandom": "^3.0.5",
    "source-map-support": "^0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.4.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/scripts"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "testPathIgnorePatterns": [
      "\\.schema\\.spec\\.ts$",
      "assistant\\.service\\.spec\\.ts$",
      "langfuse-prompt\\.service\\.spec\\.ts$",
      "desk/engine/__tests__/invocation\\.service\\.spec\\.ts$"
    ],
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "diagnostics": false,
          "isolatedModules": true
        }
      ]
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node"
  }
}
