# ===========================================================
# Console (Next.js) — Environment Variable Reference
# ===========================================================
# Copy to `.env.local` for local dev. NEXT_PUBLIC_* vars are exposed to the
# browser — never put secrets in them. All vars have localhost/empty fallbacks,
# so the console boots with zero env vars locally.
# ===========================================================

# --------------- Backend API ---------------
# Required in any deployed environment (localhost fallback in dev)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# --------------- App URLs ---------------
# Public web app URL (link targets out of the console)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# This console's own URL
NEXT_PUBLIC_CONSOLE_URL=http://localhost:3002
# Base URL for per-tenant app deep links (defaults to "/")
# NEXT_PUBLIC_TENANT_APP_URL=http://localhost:3000

# --------------- Docs-only mode ---------------
# true = serve only the public docs pages (authenticated console hidden)
# NEXT_PUBLIC_DOCS_ONLY_MODE=false

# --------------- Firebase (login UI) ---------------
# Same values as the web app (`apps/web/.env.example`). Without these, the
# login page shows an error; in dev you can use the dev-auth switcher instead.
# NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
# NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
