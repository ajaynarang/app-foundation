{
  "name": "@app/console",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next .turbo node_modules",
    "sync-openapi": "node scripts/sync-openapi.js",
    "sync-manual": "node scripts/sync-product-manual.js",
    "prebuild": "node scripts/sync-openapi.js && node scripts/sync-product-manual.js"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.1.6",
    "@app/shared-types": "workspace:*",
    "@app/ui": "workspace:*",
    "@scalar/api-reference-react": "^0.3.0",
    "@tanstack/react-query": "^5.62.9",
    "firebase": "12.8.0",
    "lucide-react": "^0.468.0",
    "next": "15.1.12",
    "next-themes": "0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5"
  }
}
