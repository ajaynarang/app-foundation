{
  "openapi": "3.0.0",
  "info": {
    "title": "Platform API",
    "description": "REST API for the platform starter — authentication, API keys, and health. Regenerate this spec from the backend's Swagger output (`pnpm --filter @app/console sync-openapi`) once you add your own domain endpoints.",
    "version": "1.0",
    "contact": {}
  },
  "servers": [
    {
      "url": "http://localhost:8000/api/v1",
      "description": "Local Development"
    }
  ],
  "tags": [
    { "name": "Health", "description": "Liveness and readiness probes" },
    { "name": "Auth", "description": "Authentication and session management" },
    { "name": "API Keys", "description": "Server-to-server API key management" }
  ],
  "paths": {
    "/health/live": {
      "get": {
        "operationId": "HealthController_live",
        "summary": "Liveness probe",
        "description": "Returns 200 when the process is up. No authentication required.",
        "tags": ["Health"],
        "security": [],
        "responses": {
          "200": {
            "description": "Service is alive",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthStatus" }
              }
            }
          }
        }
      }
    },
    "/health/ready": {
      "get": {
        "operationId": "HealthController_ready",
        "summary": "Readiness probe",
        "description": "Returns 200 when the service can reach its dependencies (database, Redis). No authentication required.",
        "tags": ["Health"],
        "security": [],
        "responses": {
          "200": {
            "description": "Service is ready",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthStatus" }
              }
            }
          },
          "503": { "description": "A dependency is unavailable" }
        }
      }
    },
    "/auth/me": {
      "get": {
        "operationId": "AuthController_me",
        "summary": "Get the authenticated user",
        "tags": ["Auth"],
        "responses": {
          "200": {
            "description": "The current user",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "401": { "description": "Missing or invalid credentials" }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "operationId": "AuthController_refresh",
        "summary": "Refresh an access token",
        "tags": ["Auth"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refreshToken"],
                "properties": {
                  "refreshToken": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "New token pair",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "accessToken": { "type": "string" },
                    "refreshToken": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "description": "Invalid or expired refresh token" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "operationId": "AuthController_logout",
        "summary": "End the current session",
        "tags": ["Auth"],
        "responses": {
          "204": { "description": "Session ended" },
          "401": { "description": "Missing or invalid credentials" }
        }
      }
    },
    "/api-keys": {
      "get": {
        "operationId": "ApiKeysController_list",
        "summary": "List API keys",
        "description": "Lists the API keys for the authenticated tenant. Key secrets are never returned after creation.",
        "tags": ["API Keys"],
        "responses": {
          "200": {
            "description": "API keys for the current tenant",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/ApiKey" }
                }
              }
            }
          },
          "401": { "description": "Missing or invalid credentials" }
        }
      },
      "post": {
        "operationId": "ApiKeysController_create",
        "summary": "Create an API key",
        "description": "Creates a new key. The plaintext secret is returned once — store it securely.",
        "tags": ["API Keys"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateApiKey" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The created key, including the plaintext secret (shown once)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiKeyWithSecret" }
              }
            }
          },
          "401": { "description": "Missing or invalid credentials" },
          "403": { "description": "Plan does not include API keys" }
        }
      }
    },
    "/api-keys/{id}": {
      "delete": {
        "operationId": "ApiKeysController_delete",
        "summary": "Delete an API key",
        "tags": ["API Keys"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": { "description": "Key deleted" },
          "404": { "description": "Key not found" }
        }
      }
    },
    "/api-keys/{id}/rotate": {
      "post": {
        "operationId": "ApiKeysController_rotate",
        "summary": "Rotate an API key",
        "description": "Issues a new secret for the key and invalidates the old one.",
        "tags": ["API Keys"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "The rotated key with its new plaintext secret (shown once)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiKeyWithSecret" }
              }
            }
          },
          "404": { "description": "Key not found" }
        }
      }
    },
    "/api-keys/{id}/revoke": {
      "post": {
        "operationId": "ApiKeysController_revoke",
        "summary": "Revoke an API key",
        "description": "Permanently disables the key. Revoked keys cannot be re-enabled.",
        "tags": ["API Keys"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "The revoked key",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiKey" }
              }
            }
          },
          "404": { "description": "Key not found" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearer": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key (sk_*) or JWT access token"
      }
    },
    "schemas": {
      "HealthStatus": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "ok" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "email": { "type": "string", "format": "email" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "role": {
            "type": "string",
            "enum": ["OWNER", "ADMIN", "MEMBER", "SUPER_ADMIN"]
          },
          "tenantId": { "type": "integer" }
        }
      },
      "CreateApiKey": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "example": "ci-pipeline" },
          "expiresAt": { "type": "string", "format": "date-time", "nullable": true }
        }
      },
      "ApiKey": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "prefix": { "type": "string", "example": "sk_staging_" },
          "isActive": { "type": "boolean" },
          "lastUsedAt": { "type": "string", "format": "date-time", "nullable": true },
          "expiresAt": { "type": "string", "format": "date-time", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "ApiKeyWithSecret": {
        "allOf": [
          { "$ref": "#/components/schemas/ApiKey" },
          {
            "type": "object",
            "properties": {
              "key": {
                "type": "string",
                "description": "Plaintext secret — returned only on create/rotate",
                "example": "sk_staging_abc123..."
              }
            }
          }
        ]
      }
    }
  },
  "security": [{ "bearer": [] }]
}
