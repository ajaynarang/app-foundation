# ===========================================================
# Web (Next.js) — Environment Variable Reference
# ===========================================================
# Copy to `.env.local` for local dev. NEXT_PUBLIC_* vars are exposed to the
# browser — never put secrets in them. Secrets are commented out.
# ===========================================================

# --------------- Backend API (Required) ---------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# --------------- Tenancy ---------------
# true  = multi-tenant (subdomain tenant resolution + tenant-aware login)
# false = single-tenant (no subdomain parsing, plain-origin cookies, tenant UI hidden)
NEXT_PUBLIC_TENANCY_MODE=multi
NEXT_PUBLIC_MULTI_TENANT=true

# --------------- App URL ---------------
# Public origin of this web app — used for Firebase password-reset continue
# URLs and other absolute links back to the app.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --------------- Console URL ---------------
NEXT_PUBLIC_CONSOLE_URL=http://localhost:3002

# --------------- Environment ---------------
NODE_ENV=development

# --------------- App Domain (multi-tenant only) ---------------
# Base domain WITHOUT protocol or subdomain prefix. Used to extract the tenant
# slug from the hostname and set cookies on the parent domain. Ignored when
# NEXT_PUBLIC_MULTI_TENANT=false. Local dev: localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000

# --------------- Dev Tools (Dev/Staging Only) ---------------
# Floating toolbar for quick user/role switching — bypasses Firebase/OTP.
# This is the first-login path when Firebase isn't configured: set BOTH vars
# below, open /login, press Ctrl+Shift+>, and pick a seeded user.
NEXT_PUBLIC_DEV_SWITCHER=true
# Required by the /api/dev/* proxy routes that power the switcher — must match
# the backend's DEV_AUTH_SECRET (apps/backend/.env).
# DEV_AUTH_SECRET=same-value-as-backend

# --------------- Firebase (Required for the login UI) ---------------
# Without these, the login page shows an error. For local dev you can also use
# the backend's dev-auth endpoint directly.
# NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
# NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# --------------- Cloudflare Turnstile (Optional — bot protection on registration) ---------------
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --------------- Sentry Error Tracking (Optional) ---------------
# Until set, captureError() is a console.log no-op.
# NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0

# --------------- Stripe Billing ---------------
# Not currently read by any app code — reserved for when you wire Stripe.js
# (client-side payment elements) into your billing UI.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_*

# --------------- Storage / CDN (Optional) ---------------
# Explicit S3 bucket hostname added to the CSP as a browser-compat fallback
# (wildcard S3 origins are always allowed). Host only, no protocol.
# NEXT_PUBLIC_S3_BUCKET_HOST=your-bucket.s3.us-east-1.amazonaws.com
# CDN base URL — used for the maintenance-mode status file and added to the
# CSP media-src.
# NEXT_PUBLIC_CDN_URL=https://your-cdn.cloudfront.net

# --------------- AI Observability (Optional) ---------------
# Langfuse deep-links on the super-admin AI Spend page. When either is unset the
# deep-link is hidden (not broken).
NEXT_PUBLIC_LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
# NEXT_PUBLIC_LANGFUSE_PROJECT_ID=your-langfuse-project-id

# --------------- External Agents Quickstart (Optional) ---------------
# MCP endpoint URL shown in the Settings > AI Assistants quickstart modal.
# Falls back to a placeholder (https://api.example.com/mcp) when unset.
# NEXT_PUBLIC_MCP_ENDPOINT_URL=https://api.your-domain.com/mcp

# --------------- Dev Banner (Optional, CI-injected) ---------------
# Branch label shown in the non-production environment banner.
# NEXT_PUBLIC_GIT_BRANCH=main
