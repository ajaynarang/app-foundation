# ===========================================================
# Web (Next.js) — Environment Variable Reference
# ===========================================================
# Copy to `.env.local` for local dev. NEXT_PUBLIC_* vars are exposed to the
# browser — never put secrets in them. Secrets are commented out.
# ===========================================================

# --------------- Backend API (Required) ---------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# --------------- Tenancy ---------------
# true  = multi-tenant (subdomain tenant resolution + tenant-aware login)
# false = single-tenant (no subdomain parsing, plain-origin cookies, tenant UI hidden)
NEXT_PUBLIC_MULTI_TENANT=true

# --------------- Console URL ---------------
NEXT_PUBLIC_CONSOLE_URL=http://localhost:3002

# --------------- Environment ---------------
NODE_ENV=development

# --------------- App Domain (multi-tenant only) ---------------
# Base domain WITHOUT protocol or subdomain prefix. Used to extract the tenant
# slug from the hostname and set cookies on the parent domain. Ignored when
# NEXT_PUBLIC_MULTI_TENANT=false. Local dev: localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000

# --------------- Dev Tools (Dev/Staging Only) ---------------
# Floating toolbar for quick user/role switching — bypasses Firebase/OTP
# NEXT_PUBLIC_DEV_SWITCHER=true

# --------------- Firebase (Required for the login UI) ---------------
# Without these, the login page shows an error. For local dev you can also use
# the backend's dev-auth endpoint directly.
# NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
# NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# --------------- Cloudflare Turnstile (Optional — bot protection on registration) ---------------
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --------------- Sentry Error Tracking (Optional) ---------------
# Until set, captureError() is a console.log no-op.
# NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0

# --------------- Stripe Billing ---------------
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_*

# --------------- AI Observability (Optional) ---------------
# Langfuse deep-links on the super-admin AI Spend page. When either is unset the
# deep-link is hidden (not broken).
NEXT_PUBLIC_LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
# NEXT_PUBLIC_LANGFUSE_PROJECT_ID=your-langfuse-project-id
