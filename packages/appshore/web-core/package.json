{
  "name": "@appshore/web-core",
  "version": "0.1.0",
  "private": true,
  "description": "AppShore web foundation — api client, auth stores/providers, realtime, shared hooks/config (source-consumed via tsconfig paths)",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "lint": "eslint src/ --no-error-on-unmatched-pattern",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@app/shared-types": "workspace:*",
    "@app/ui": "workspace:*",
    "@date-fns/tz": "^1.5.0",
    "@tanstack/react-query": "^5.62.9",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "12.8.0",
    "framer-motion": "12.29.2",
    "lucide-react": "^0.468.0",
    "next": "15.1.12",
    "tailwind-merge": "^2.6.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {}
}
