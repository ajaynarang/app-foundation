{
  "name": "@appshore/platform",
  "version": "0.1.0",
  "private": true,
  "description": "AppShore platform — Prisma-coupled SaaS foundation: auth, tenancy, queues, storage, health, platform domains",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json",
    "./*": "./dist/*.js"
  },
  "typesVersions": {
    "*": {
      "dist/*": [
        "dist/*"
      ],
      "*": [
        "dist/*"
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "jest --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@app/shared-types": "workspace:*",
    "@appshore/db": "workspace:*",
    "@appshore/kernel": "workspace:*",
    "@aws-sdk/client-s3": "^3.995.0",
    "@aws-sdk/s3-request-presigner": "^3.995.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "11.0.5",
    "@nestjs/swagger": "11.2.5",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "7.3.0",
    "bcrypt": "6.0.0",
    "bullmq": "^5.69.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.3",
    "express": "5.2.1",
    "firebase-admin": "13.6.0",
    "ioredis": "5.9.2",
    "nanoid": "3.3.11",
    "nodemailer": "7.0.13",
    "passport-jwt": "4.0.1",
    "pg": "8.17.2",
    "resend": "6.9.1",
    "twilio": "^5.12.1",
    "ua-parser-js": "^2.0.10",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "^22.10.7",
    "jest": "30.2.0",
    "ts-jest": "29.4.6",
    "typescript": "^5.9.3",
    "@nestjs/testing": "11.1.12"
  }
}
