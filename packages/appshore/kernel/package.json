{
  "name": "@appshore/kernel",
  "version": "0.1.0",
  "private": true,
  "description": "AppShore kernel — DB-free, product-agnostic mechanics (logging, events, retry, SSE, utils)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json",
    "./*": "./dist/*.js"
  },
  "typesVersions": {
    "*": {
      "dist/*": [
        "dist/*"
      ],
      "*": [
        "dist/*"
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "jest --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@app/shared-types": "workspace:*",
    "@langfuse/otel": "^5.4.0",
    "@langfuse/tracing": "^5.4.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "4.0.2",
    "@nestjs/event-emitter": "^3.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.70.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "bullmq": "^5.69.3",
    "class-validator": "0.14.3",
    "cron-parser": "^5.5.0",
    "express": "5.2.1",
    "nanoid": "3.3.11",
    "pino": "10.3.0",
    "rxjs": "^7.8.1",
    "twilio": "^5.12.1",
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "^22.10.7",
    "jest": "30.2.0",
    "ts-jest": "29.4.6",
    "typescript": "^5.9.3",
    "@nestjs/testing": "11.1.12"
  }
}
