  periodEnd         DateTime             @map("period_end") @db.Timestamptz
  lineItems         Json                 @map("line_items") @db.JsonB
  pdfUrl            String?              @map("pdf_url") @db.Text
  hostedInvoiceUrl  String?              @map("hosted_invoice_url") @db.Text
