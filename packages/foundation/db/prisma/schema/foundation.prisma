model TenantCounter {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @map("tenant_id")
  key       String   @map("key") @db.VarChar(50)
  value     Int      @default(0) @map("value")
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, key])
  @@map("tenant_counters")
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model Job {
  id           Int       @id @default(autoincrement()) @map("id")
  tenantId     Int       @map("tenant_id")
  submittedBy  Int?      @map("submitted_by")
  category     String    @map("category") @db.VarChar(30)
  type         String    @map("type") @db.VarChar(50)
  status       JobStatus @default(QUEUED)
  priority     Int       @default(0) @map("priority")
  inputData    Json      @map("input_data") @db.JsonB
  resultData   Json?     @map("result_data") @db.JsonB
  errorMessage String?   @map("error_message") @db.Text
  errorDetails Json?     @map("error_details") @db.JsonB
  attempts     Int       @default(0) @map("attempts")
  maxAttempts  Int       @default(3) @map("max_attempts")
  progress     Int?      @map("progress")
  inputHash    String?   @map("input_hash") @db.VarChar(64)
  queuedAt     DateTime  @default(now()) @map("queued_at") @db.Timestamptz
  startedAt    DateTime? @map("started_at") @db.Timestamptz
  completedAt  DateTime? @map("completed_at") @db.Timestamptz
  dismissedAt  DateTime? @map("dismissed_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  tenant          Tenant @relation(fields: [tenantId], references: [id])
  submittedByUser User?  @relation("jobsSubmitted", fields: [submittedBy], references: [id])

  @@index([tenantId, status])
  @@index([category, type, status])
  @@index([submittedBy, status])
  @@index([tenantId, inputHash])
  @@index([tenantId, category, createdAt], map: "jobs_tenant_category_created")
  @@map("jobs")
}

model JobSchedule {
  id           Int      @id @default(autoincrement())
  category     String   @db.VarChar(50)
  jobType      String   @map("job_type") @db.VarChar(50)
  scheduleType String   @map("schedule_type") @db.VarChar(20) // 'cron' | 'interval'
  pattern      String?  @db.VarChar(100)
  intervalMs   Int?     @map("interval_ms")
  isEnabled    Boolean  @default(true) @map("is_enabled")
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy    Int?     @map("updated_by")

  @@unique([category, jobType])
  @@map("job_schedules")
}

