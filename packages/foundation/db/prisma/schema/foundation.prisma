// ─────────────────────────────────────────────────────────────────────────────
// TENANT DELETION POLICY: tenants are never hard-deleted. Suspend them
// (Tenant.status = SUSPENDED / isActive = false) instead. Child relations use
// a mix of Cascade (ephemeral/audit data) and Restrict (business data) that
// intentionally blocks a hard DELETE. If you need true offboarding, write an
// explicit purge job — do not "fix" the Restrict edges.
// ─────────────────────────────────────────────────────────────────────────────
generator client {
  provider = "prisma-client-js"
  output   = "../../generated/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// AUTHENTICATION & MULTI-TENANCY MODELS
// ============================================================================

enum UserRole {
  OWNER // Tenant owner - created during registration, cannot be deleted
  ADMIN
  MEMBER
  SUPER_ADMIN
}

enum TenantStatus {
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  SUSPENDED
}

enum TenantPlan {
  TRIAL
  TRIAL_EXPIRED
  STARTER
  PROFESSIONAL
  ENTERPRISE
  SUSPENDED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  CANCELLED
  EXPIRED
}

enum InvitationChannel {
  EMAIL
  SMS
}

enum SupportCategory {
  BILLING
  TECHNICAL
  FEATURE_REQUEST
  ACCOUNT
  INTEGRATION
  GENERAL
}

enum SupportPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  RESOLVED
  CLOSED
}

enum BillingProviderType {
  STRIPE
}

enum BillingSubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  SUSPENDED
  TRIALING
}

enum BillingInvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum PaymentMethodType {
  CARD
  US_BANK_ACCOUNT
}

enum WalletTransactionType {
  TOP_UP
  OVERAGE_DEDUCTION
  ADMIN_CREDIT
  REFUND
  AUTO_RELOAD
}

model Tenant {
  id           Int     @id @default(autoincrement())
  tenantId     String  @unique @map("tenant_id") @db.VarChar(50)
  companyName  String  @map("company_name") @db.VarChar(255)
  subdomain    String? @unique @db.VarChar(100)
  contactEmail String? @map("contact_email") @db.VarChar(255)
  contactPhone String? @map("contact_phone") @db.VarChar(50)

  // Registration fields
  status TenantStatus @default(PENDING_APPROVAL)

  // Approval tracking
  approvedAt      DateTime? @map("approved_at") @db.Timestamptz
  approvedBy      String?   @map("approved_by") @db.VarChar(100)
  rejectedAt      DateTime? @map("rejected_at") @db.Timestamptz
  rejectionReason String?   @map("rejection_reason")

  // Suspension tracking
  suspendedAt      DateTime? @map("suspended_at") @db.Timestamptz
  suspendedBy      String?   @map("suspended_by") @db.VarChar(100)
  suspensionReason String?   @map("suspension_reason")

  // Reactivation tracking
  reactivatedAt DateTime? @map("reactivated_at") @db.Timestamptz
  reactivatedBy String?   @map("reactivated_by") @db.VarChar(100)

  // Onboarding tracking
  onboardingCompletedAt DateTime? @map("onboarding_completed_at") @db.Timestamptz
  onboardingProgress    Json?     @map("onboarding_progress") @db.JsonB

  // Timezone for scheduled Desk responsibilities (IANA identifier, e.g. "America/Chicago")
  timezone String? @default("UTC") @db.VarChar(60)

  // Tenant-wide master switch for autonomous Desk runs. When false (default),
  // NO responsibility runs autonomously regardless of per-responsibility
  // `autonomyEnabled` — the scheduler (and any future non-manual trigger)
  // skips the whole tenant. A one-flip "pause all autonomous runs" safety
  // control. Manual "Run now" is unaffected. (Column name kept as
  // `deskScheduleEnabled` for migration stability.)
  deskScheduleEnabled Boolean @default(false) @map("desk_schedule_enabled")

  // When true, this tenant's AI traffic must route through zero-data-retention
  // (ZDR) provider endpoints — no prompt/response retention at the provider.
  // Enforced in AiProvider.resolveModel; if no ZDR-eligible model exists for
  // the requested tier, the call throws ZeroRetentionUnavailable. For
  // compliance-sensitive customers.
  aiZeroRetention Boolean @default(false) @map("ai_zero_retention")

  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Plan & billing
  plan           TenantPlan @default(TRIAL) @map("plan")
  trialStartedAt DateTime?  @map("trial_started_at") @db.Timestamptz
  trialEndsAt    DateTime?  @map("trial_ends_at") @db.Timestamptz
  planAssignedAt DateTime?  @map("plan_assigned_at") @db.Timestamptz
  planAssignedBy String?    @map("plan_assigned_by") @db.VarChar(100)

  // Job control
  jobsPaused   Boolean   @default(false) @map("jobs_paused")
  jobsPausedAt DateTime? @map("jobs_paused_at") @db.Timestamptz
  jobsPausedBy Int?      @map("jobs_paused_by")

  users                       User[]
  loginEvents                 LoginEvent[]
  integrationConfigs          IntegrationConfig[]
  invitations                 UserInvitation[]
  notifications               Notification[]
  conversations               Conversation[]
  supportTickets              SupportTicket[]
  jobs                        Job[]
  counters                    TenantCounter[]
  planEvents                  TenantPlanEvent[]
  webhookSubscriptions        WebhookSubscription[]
  domainEventLogs             DomainEventLog[]
  deadLetters                 DeadLetterLog[]
  conversationSessions        ConversationSession[]
  integrationExternalEntities IntegrationExternalEntity[]
  integrationEntityMappings   IntegrationEntityMapping[]
  oauthClients                OAuthClient[]
  tenantAddOns                TenantAddOn[]
  pushSubscriptions           PushSubscription[]
  feedback                    Feedback[]

  // Billing & wallet
  billingCustomer      BillingCustomer?
  billingSubscriptions BillingSubscription[]
  wallet               Wallet?
  walletTransactions   WalletTransaction[]
  billingInvoices      BillingInvoice[]
  paymentMethods       PaymentMethod[]

  // Desk + AI
  deskAgents             DeskAgent[]
  deskResponsibilities   DeskResponsibility[]
  deskEpisodes           DeskEpisode[]
  deskMemories           DeskMemory[]
  deskEntitySuppressions DeskEntitySuppression[]
  tenantJobRuns          TenantJobRun[]
  agentInvocationLogs    AgentInvocationLog[]
  hitlChallenges         HitlChallenge[]
  aiInvocations          AiInvocation[]
  aiBudget               TenantAiBudget?

  @@index([status])
  // Serves the every-minute scheduler heartbeat scan for tenants with the
  // master Desk-autonomy switch on (desk-scheduler.processor.ts).
  @@index([deskScheduleEnabled])
  @@map("tenants")
}

model User {
  id     Int    @id @default(autoincrement())
  userId String @unique @map("user_id") @db.VarChar(50)

  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  tenantId Int?    @map("tenant_id")

  email        String?  @db.VarChar(255)
  passwordHash String?  @map("password_hash") @db.VarChar(255)
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  role         UserRole

  // Firebase integration
  firebaseUid   String? @unique @map("firebase_uid") @db.VarChar(128)
  emailVerified Boolean @default(false) @map("email_verified")

  // Phone authentication
  phone         String? @unique @db.VarChar(20)
  phoneVerified Boolean @default(false) @map("phone_verified")
  pinHash       String? @map("pin_hash") @db.VarChar(255)

  // Status tracking
  isActive          Boolean   @default(true) @map("is_active")
  lastLoginAt       DateTime? @map("last_login_at") @db.Timestamptz
  passwordChangedAt DateTime? @map("password_changed_at") @db.Timestamptz

  // Soft delete
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz
  deletedBy      Int?      @map("deleted_by")
  deletedByUser  User?     @relation("DeletedBy", fields: [deletedBy], references: [id])
  deletedUsers   User[]    @relation("DeletedBy")
  deletionReason String?   @map("deletion_reason")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  loginEvents             LoginEvent[]
  apiKeys                 ApiKey[]
  preferences             UserPreferences?
  superAdminPreferences   SuperAdminPreferences?
  invitationsSent         UserInvitation[]         @relation("InvitedBy")
  invitationsAccepted     UserInvitation[]         @relation("AcceptedBy")
  notifications           Notification[]
  pushSubscriptions       PushSubscription[]
  conversations           Conversation[]
  jobsSubmitted           Job[]                    @relation("jobsSubmitted")
  oauthClientsCreated     OAuthClient[]            @relation("OAuthClientCreator")
  oauthAuthorizationCodes OAuthAuthorizationCode[]
  oauthAccessTokens       OAuthAccessToken[]
  oauthRefreshTokens      OAuthRefreshToken[]
  feedbackSubmitted       Feedback[]               @relation("FeedbackSubmitter")
  feedbackResolved        Feedback[]               @relation("FeedbackResolver")
  supportTicketsCreated   SupportTicket[]          @relation("supportTicketCreator")
  supportMessages         SupportTicketMessage[]   @relation("supportMessageAuthor")
  announcements           Announcement[]           @relation("AnnouncementCreatedBy")
  supervisedDeskAgents    DeskAgent[]              @relation("DeskAgentSupervisor")
  deskApprovalsClaimed    DeskApproval[]           @relation("DeskApprovalClaimedBy")
  deskApprovalsDecided    DeskApproval[]           @relation("DeskApprovalDecidedBy")
  deskSuppressionsSet     DeskEntitySuppression[]  @relation("DeskSuppressionSet")
  deskSuppressionsUnset   DeskEntitySuppression[]  @relation("DeskSuppressionUnset")
  deskMemoriesAuthored    DeskMemory[]             @relation("DeskMemoryAuthoredBy")
  aiInvocations           AiInvocation[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@index([phone])
  @@index([firebaseUid])
  @@index([role])
  @@index([isActive])
  @@index([deletedAt])
  @@index([deletedBy])
  @@map("users")
}

model SuperAdminPreferences {
  id     Int  @id @default(autoincrement())
  userId Int  @unique @map("user_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  notifyNewTenants      Boolean @default(true) @map("notify_new_tenants")
  notifyStatusChanges   Boolean @default(true) @map("notify_status_changes")
  notificationFrequency String  @default("immediate") @map("notification_frequency") @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("super_admin_preferences")
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  tokenId   String    @unique @map("token_id") @db.VarChar(50)
  userId    Int       @map("user_id")
  token     String    @db.VarChar(500)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  isRevoked Boolean   @default(false) @map("is_revoked")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

/// One-time token for the first-party "forgot password" flow. Only the SHA-256
/// hash is stored; the raw token goes into the emailed reset link.
model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tokenHash String    @unique @map("token_hash") @db.VarChar(128)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

enum LoginEventStatus {
  SUCCESS
  FAILED
  LOGOUT
}

enum LoginFailReason {
  ACCOUNT_DISABLED
  TENANT_INACTIVE
  INVALID_TOKEN
  INVALID_CREDENTIALS
  USER_NOT_FOUND
  OTHER

  @@map("login_fail_reason")
}

model LoginEvent {
  id         Int              @id @default(autoincrement())
  userId     Int              @map("user_id")
  tenantId   Int?             @map("tenant_id")
  status     LoginEventStatus
  ip         String?          @db.VarChar(45)
  userAgent  String?          @map("user_agent") @db.Text
  deviceId   String?          @map("device_id") @db.VarChar(64)
  failReason LoginFailReason? @map("fail_reason")
  sessionId  String?          @map("session_id") @db.VarChar(50)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
  @@index([createdAt])
  @@index([tenantId, status, createdAt(sort: Desc)], name: "idx_login_event_tenant_status_created")
  @@index([tenantId, userId, createdAt(sort: Desc)], name: "idx_login_event_tenant_user_created")
  @@map("login_events")
}

model ApiKey {
  id     Int    @id @default(autoincrement())
  key    String @unique @db.VarChar(64)
  name   String @db.VarChar(255)
  userId Int    @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Usage tracking
  lastUsedAt   DateTime? @map("last_used_at") @db.Timestamptz
  requestCount Int       @default(0) @map("request_count")

  // Phase B — scoped keys
  scopes              String[] @default([])
  ipAllowlist         String[] @default([]) @map("ip_allowlist")
  rateLimitPerMinute  Int      @default(300) @map("rate_limit_per_minute")
  isWriteEnabled      Boolean  @default(false) @map("is_write_enabled")
  lastValidationError String?  @map("last_validation_error") @db.Text

  // Status
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  expiresAt DateTime? @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz

  @@index([userId])
  @@index([userId, revokedAt])
  @@map("api_keys")
}

model UserInvitation {
  id           Int    @id @default(autoincrement())
  invitationId String @unique @default(uuid()) @map("invitation_id")

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId Int    @map("tenant_id")

  email         String?           @db.VarChar(255)
  phone         String?           @db.VarChar(20)
  inviteChannel InvitationChannel @default(EMAIL) @map("invite_channel")
  firstName     String            @map("first_name") @db.VarChar(100)
  lastName      String            @map("last_name") @db.VarChar(100)
  role          UserRole

  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz

  invitedBy     Int  @map("invited_by")
  invitedByUser User @relation("InvitedBy", fields: [invitedBy], references: [id])

  status           InvitationStatus @default(PENDING)
  acceptedAt       DateTime?        @map("accepted_at") @db.Timestamptz
  acceptedByUserId Int?             @map("accepted_by_user_id")
  acceptedByUser   User?            @relation("AcceptedBy", fields: [acceptedByUserId], references: [id])

  cancelledAt        DateTime? @map("cancelled_at") @db.Timestamptz
  cancellationReason String?   @map("cancellation_reason")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  notifications Notification[]

  @@index([tenantId])
  @@index([email])
  @@index([expiresAt])
  @@index([status])
  @@index([invitedBy])
  @@index([acceptedByUserId])
  @@map("user_invitations")
}

// ============================================================================
// DOCUMENTS (generic file store)
// ============================================================================

// ============================================================================
// INTEGRATIONS FRAMEWORK
// ============================================================================

enum IntegrationType {
  ACCOUNTING
}

enum IntegrationVendor {
  QUICKBOOKS
}

enum IntegrationStatus {
  NOT_CONFIGURED
  CONFIGURED
  ACTIVE
  ERROR
  DISABLED
  NEEDS_RECONNECT
}

/// Generic cache of entities fetched from external systems (e.g. customers, accounts, categories).
/// Not used by the starter itself — this is an extension-point table for integration
/// connectors you add to VENDOR_REGISTRY (see CLAUDE.md "Integration connectors").
model IntegrationExternalEntity {
  id            Int      @id @default(autoincrement())
  tenantId      Int      @map("tenant_id")
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  integrationId String   @map("integration_id") @db.VarChar(50)
  entityType    String   @map("entity_type") @db.VarChar(50)
  externalId    String   @map("external_id") @db.VarChar(100)
  externalName  String   @map("external_name") @db.VarChar(500)
  metadata      Json?    @db.JsonB
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([integrationId, entityType, externalId])
  @@index([tenantId])
  @@map("integration_external_entities")
}

/// Generic mapping from a platform entity to an external entity in an integrated system.
/// Not used by the starter itself — extension-point table for integration connectors
/// (pairs with IntegrationExternalEntity above).
model IntegrationEntityMapping {
  id               Int       @id @default(autoincrement())
  tenantId         Int       @map("tenant_id")
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  integrationId    String    @map("integration_id") @db.VarChar(50)
  entityType       String    @map("entity_type") @db.VarChar(50)
  internalEntityId String    @map("internal_entity_id") @db.VarChar(50)
  externalId       String?   @map("external_id") @db.VarChar(100)
  externalName     String?   @map("external_name") @db.VarChar(500)
  matchConfidence  Float?    @map("match_confidence")
  confirmedAt      DateTime? @map("confirmed_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([integrationId, entityType, internalEntityId], map: "iem_integration_type_internal_unique")
  @@index([tenantId])
  @@map("integration_entity_mappings")
}

model IntegrationConfig {
  id            Int    @id @default(autoincrement())
  integrationId String @unique @map("integration_id") @db.VarChar(50)

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId Int    @map("tenant_id")

  integrationType IntegrationType   @map("integration_type")
  vendor          IntegrationVendor
  displayName     String            @map("display_name") @db.VarChar(200)
  isEnabled       Boolean           @default(false) @map("is_enabled")
  status          IntegrationStatus @default(NOT_CONFIGURED)

  // Encrypted credentials (JSON stored as text)
  credentials Json? @db.JsonB

  // Plaintext QB realm ID for fast webhook routing (not sensitive)
  /// Vendor account / workspace identifier (e.g. a QuickBooks realm, a Xero org).
  realmId String? @map("realm_id") @db.VarChar(30)

  // Sync settings
  syncIntervalSeconds Int? @map("sync_interval_seconds")

  // Health monitoring
  lastSyncAt       DateTime? @map("last_sync_at") @db.Timestamptz
  lastSuccessAt    DateTime? @map("last_success_at") @db.Timestamptz
  lastErrorAt      DateTime? @map("last_error_at") @db.Timestamptz
  lastErrorMessage String?   @map("last_error_message") @db.Text
  syncMetadata     Json?     @map("sync_metadata") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, integrationType, vendor])
  @@index([status])
  @@map("integration_configs")
}

/// Runtime control for vendor availability and features.
/// Static metadata (OAuth URLs, scopes, credential fields) lives in code (VENDOR_REGISTRY).
/// This table provides operational overrides: enable/disable vendors, toggle OAuth, UI ordering.
model VendorConfig {
  id                Int      @id @default(autoincrement())
  vendorId          String   @unique @map("vendor_id") @db.VarChar(50)
  isAvailable       Boolean  @default(true) @map("is_available")
  isOAuthEnabled    Boolean  @default(true) @map("is_oauth_enabled")
  displayOrder      Int      @default(0) @map("display_order")
  customDisplayName String?  @map("custom_display_name") @db.VarChar(100)
  metadata          Json?    @db.JsonB
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("vendor_configs")
}

// ============================================================================
// USER PREFERENCES MODELS
// ============================================================================

model UserPreferences {
  id     Int  @id @default(autoincrement())
  userId Int  @unique @map("user_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Display Preferences
  distanceUnit String @default("MILES") @map("distance_unit") @db.VarChar(20) // MILES | KILOMETERS
  timeFormat   String @default("12H") @map("time_format") @db.VarChar(10) // 12H | 24H
  timezone     String @default("UTC") @db.VarChar(100)
  dateFormat   String @default("MM/DD/YYYY") @map("date_format") @db.VarChar(20)

  // Alert Delivery (per-priority channel overrides)
  // User's override of tenant defaults. Empty = use tenant defaults.
  // Shape: { "critical": { "inApp": true, "email": true, "push": true, "sms": true }, ... }
  alertChannels Json @default("{}") @map("alert_channels") @db.JsonB

  // Sound (alert-path: used by resolveChannels in alert pipeline)
  soundSettings Json @default("{\"critical\":true,\"high\":true,\"medium\":false,\"low\":false}") @map("sound_settings") @db.JsonB

  // Notification Preferences (redesign)
  notificationPreferences Json? @map("notification_preferences") @db.JsonB

  // Quiet Hours
  quietHoursEnabled Boolean @default(false) @map("quiet_hours_enabled")
  quietHoursStart   String? @map("quiet_hours_start") @db.VarChar(10)
  quietHoursEnd     String? @map("quiet_hours_end") @db.VarChar(10)

  // Platform Tour
  platformTourStatus   String?   @map("platform_tour_status") @db.VarChar(20) // null | dismissed | completed
  platformTourStatusAt DateTime? @map("platform_tour_status_at") @db.Timestamptz

  // Voice Preferences
  voiceMode  String @default("manual") @map("voice_mode") @db.VarChar(10) // manual | auto
  voiceId    String @default("warm") @map("voice_id") @db.VarChar(20) // warm | confident | calm
  voiceSpeed String @default("normal") @map("voice_speed") @db.VarChar(10) // slowest | slow | normal | fast | fastest

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([userId])
  @@map("user_preferences")
}

// ============================================================================
// FEATURE FLAGS MODEL
// ============================================================================

model FeatureFlag {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.VarChar(100)
  name        String   @db.VarChar(200)
  description String?  @db.Text
  enabled     Boolean  @default(false)
  category    String   @default("general") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([key])
  @@index([category])
  @@index([enabled])
  @@map("feature_flags")
}

// ============================================================================
// NOTIFICATION MODELS
// ============================================================================

enum NotificationType {
  // Platform
  USER_INVITATION
  TENANT_REGISTRATION_CONFIRMATION
  TENANT_APPROVED
  TENANT_REJECTED

  // System
  INTEGRATION_SYNC_COMPLETED
  INTEGRATION_SYNC_FAILED
  SETTINGS_UPDATED

  // Team
  USER_JOINED
  ROLE_CHANGED
}

enum NotificationChannel {
  EMAIL
  SMS // Future
  PUSH // Future
  IN_APP // Future
}

enum NotificationCategory {
  SYSTEM
  TEAM
  BILLING
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model Notification {
  id             Int    @id @default(autoincrement())
  notificationId String @unique @default(cuid()) @map("notification_id") @db.VarChar(50)

  // Notification details
  type      NotificationType
  channel   NotificationChannel @default(EMAIL)
  recipient String              @db.VarChar(255)
  status    NotificationStatus  @default(PENDING)

  // Related entities (nullable - depends on notification type)
  tenantId     Int?            @map("tenant_id")
  tenant       Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       Int?            @map("user_id")
  user         User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitationId Int?            @map("invitation_id")
  invitation   UserInvitation? @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  // In-App Notification fields
  category    NotificationCategory @map("category")
  title       String?              @db.VarChar(255)
  message     String?              @db.Text
  actionUrl   String?              @map("action_url") @db.VarChar(500)
  actionLabel String?              @map("action_label") @db.VarChar(100)
  iconType    String?              @map("icon_type") @db.VarChar(30)
  readAt      DateTime?            @map("read_at") @db.Timestamptz
  dismissedAt DateTime?            @map("dismissed_at") @db.Timestamptz
  groupKey    String?              @map("group_key") @db.VarChar(100)
  groupCount  Int                  @default(1) @map("group_count")
  emailJobId  String?              @map("email_job_id") @db.VarChar(100)
  smsJobId    String?              @map("sms_job_id") @db.VarChar(100)

  // Metadata
  metadata     Json?     @db.JsonB
  errorMessage String?   @map("error_message") @db.Text
  sentAt       DateTime? @map("sent_at") @db.Timestamptz

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([userId])
  @@index([invitationId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([tenantId, status])
  @@index([type, status])
  @@index([userId, readAt, dismissedAt])
  @@index([userId, category, createdAt])
  @@index([type, userId, tenantId, createdAt], map: "idx_notification_grouping")
  @@map("notifications")
}

