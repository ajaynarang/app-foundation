  @@index([tenantId])
  @@index([billingCustomerId])
  @@map("payment_methods")
}

model ProcessedBillingEvent {
  id              String   @id @default(cuid())
  providerEventId String   @unique @map("provider_event_id") @db.VarChar(255)
  eventType       String   @map("event_type") @db.VarChar(100)
  processedAt     DateTime @default(now()) @map("processed_at") @db.Timestamptz

  @@map("processed_billing_events")
}

// ============================================================================
// DESK — Agentic workflow engine
//
// Layers:
//   • DeskAgent            — AI personas
//   • DeskResponsibility   — per-tenant config (trust, conditions, notes)
//   • DeskEpisode          — one run against one entity; durable
//   • DeskEpisodeStep      — atomic audit row (hydrate/perceive/decide/draft/gate/execute/close)
//   • DeskApproval         — human decisions on gated steps
//   • DeskMemory           — agent-scoped long-term learning (pgvector)
//
// Execution state lives in the durable workflow engine (linked via workflow_id).
// These tables own config + audit only.
// ============================================================================

enum TrustLevel {
  SUPERVISED
  ASSISTED
  AUTONOMOUS
}

enum Lifecycle {
  AVAILABLE
  COMING_SOON
}

enum TriggerKind {
  SCHEDULED
  DOMAIN_EVENT
  WEBHOOK
  MANUAL
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ApprovalDecision {
  APPROVED
  EDITED
  REJECTED
}

enum DeskEpisodeStatus {
  RUNNING
  WAITING_APPROVAL
  RESOLVED
  ESCALATED
  FAILED
  REJECTED_BY_OPERATOR
  CANCELLED
  EXPIRED
}

enum DeskEpisodeStepKind {
  HYDRATE
  PERCEIVE
  DECIDE
  DRAFT
  GATE
  EXECUTE
  CLOSE
}

enum DeskEpisodeStepStatus {
  RUNNING
  SUCCEEDED
  FAILED
  GATED
  SKIPPED
}

model DeskAgent {
  id               Int      @id @default(autoincrement())
  tenantId         Int      @map("tenant_id")
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key              String   @db.VarChar(40)
  name             String   @db.VarChar(80)
  description      String?  @map("description") @db.Text
  systemPromptKey  String   @map("system_prompt_key") @db.VarChar(120)
  isActive         Boolean  @default(true) @map("is_active")
  supervisorUserId Int?     @map("supervisor_user_id")
  supervisor       User?    @relation("DeskAgentSupervisor", fields: [supervisorUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  responsibilities DeskResponsibility[]
  episodes         DeskEpisode[]
  steps            DeskEpisodeStep[]
  memories         DeskMemory[]

  @@unique([tenantId, key])
  @@index([supervisorUserId])
  @@map("desk_agents")
}

model DeskResponsibility {
  id       Int       @id @default(autoincrement())
  tenantId Int       @map("tenant_id")
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId  Int       @map("agent_id")
  agent    DeskAgent @relation(fields: [agentId], references: [id])

  key         String    @db.VarChar(60)
  title       String    @db.VarChar(160)
  description String?   @db.Text
  lifecycle   Lifecycle @default(COMING_SOON)
  enabled     Boolean   @default(true)

  // Autonomy switch: when true (and the tenant master switch is on), this
  // responsibility may run on its OWN — any non-manual trigger (scheduled
  // today; domain-event / webhook in the future). Default FALSE — a new
  // responsibility never runs on its own until an operator opts in; testing
  // happens via the manual "Run now" trigger, which ignores this flag.
  autonomyEnabled Boolean @default(false) @map("autonomy_enabled")

  // User-editable policy (UI settings page)
  trustLevel TrustLevel @default(SUPERVISED) @map("trust_level")
  conditions Json       @default("{}") @db.JsonB // typed per-responsibility

  lastRunAt DateTime? @map("last_run_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  episodes DeskEpisode[]

  @@unique([tenantId, key])
  @@index([tenantId, enabled, lifecycle])
  @@index([agentId])
  @@map("desk_responsibilities")
}

/// Per-(tenant, job) idempotency stamp for tenant-local time-of-day jobs.
/// The hourly heartbeat records the tenant-local date a job last fired for
/// that tenant, so a later tick or retry the same local day is a no-op.
/// Keyed by (tenantId, jobKey) so a new time-of-day job is a new `jobKey`
/// value (data), not a new column on Tenant.
model TenantJobRun {
  id       Int    @id @default(autoincrement())
  tenantId Int    @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  jobKey      String   @map("job_key") @db.VarChar(60)
  lastRunDate DateTime @map("last_run_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, jobKey])
  @@index([tenantId])
  @@map("tenant_job_runs")
}

model DeskEpisode {
  /// UUIDv7, generated via generateUuidV7() in shared/utils/uuidv7.ts.
  id       String @id @db.Uuid
  tenantId Int    @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  responsibilityId Int                @map("responsibility_id")
  responsibility   DeskResponsibility @relation(fields: [responsibilityId], references: [id])
  ownerAgentId     Int                @map("owner_agent_id")
  ownerAgent       DeskAgent          @relation(fields: [ownerAgentId], references: [id])

  // Snapshots — frozen at open; mid-flight admin edits don't apply retroactively
  trustLevelSnapshot TrustLevel @map("trust_level_snapshot")
  conditionsSnapshot Json       @map("conditions_snapshot") @db.JsonB

  // Trigger metadata
  triggerKind    TriggerKind @map("trigger_kind")
  triggerLabel   String      @map("trigger_label") @db.VarChar(160)
  triggerSource  String?     @map("trigger_source") @db.VarChar(160)
  triggerFiredAt DateTime    @map("trigger_fired_at") @db.Timestamptz
  triggerPayload Json?       @map("trigger_payload") @db.JsonB

  // Entity
  entityType  String? @map("entity_type") @db.VarChar(40)
  entityId    String? @map("entity_id") @db.VarChar(120)
  entityLabel String? @map("entity_label") @db.VarChar(200)

  // State
  status    DeskEpisodeStatus
  priority  Priority          @default(NORMAL)
  dedupeKey String            @map("dedupe_key") @db.VarChar(200)

  // Outcome (set by close step)
  outcome     String? @db.VarChar(40)
  outcomeNote String? @map("outcome_note") @db.Text

  // Workflow-engine linkage — the durable engine owns execution state
  workflowId    String  @map("workflow_id") @db.VarChar(200)
  workflowRunId String? @map("workflow_run_id") @db.VarChar(100)

  openedAt  DateTime  @default(now()) @map("opened_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  closedAt  DateTime? @map("closed_at") @db.Timestamptz
  expiresAt DateTime? @map("expires_at") @db.Timestamptz

  // Memory rows hydrate retrieved for this episode. Persisted at hydrate
  // time so the reinforcer (close.step) can walk the same set without
  // re-querying. Surfaced to the UI via DeskEpisodeDetail.
  retrievedMemoryIds String[] @default([]) @map("retrieved_memory_ids") @db.Uuid

  steps              DeskEpisodeStep[]
  approvals          DeskApproval[]
  entitySuppressions DeskEntitySuppression[]
  memories           DeskMemory[]            @relation("DeskMemorySource")

  // NOTE: (tenant_id, dedupe_key) uniqueness enforced by partial unique index
  // created in raw SQL (migration adds WHERE status IN ('RUNNING','WAITING_APPROVAL')).
  // Prisma cannot express the WHERE clause.
  @@index([tenantId, dedupeKey])
  @@index([tenantId, status, priority])
  @@index([tenantId, responsibilityId, status])
  @@index([entityType, entityId])
  @@index([workflowId])
  @@index([ownerAgentId])
  @@map("desk_episodes")
}

model DeskEpisodeStep {
  /// UUIDv7, generated via generateUuidV7() in shared/utils/uuidv7.ts.
  id        String      @id @db.Uuid
  episodeId String      @map("episode_id") @db.Uuid
  episode   DeskEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  agentId Int?       @map("agent_id") // null for non-LLM steps
  agent   DeskAgent? @relation(fields: [agentId], references: [id])

  sequence Int // monotonic insertion order
  kind     DeskEpisodeStepKind
  status   DeskEpisodeStepStatus

  // LLM metadata (null for non-LLM steps).
  model     String? @db.VarChar(20)
  promptKey String? @map("prompt_key") @db.VarChar(120)

  /// Foreign key into the AiInvocation ledger — the single source of truth
  /// for this step's token counts + USD cost.
  aiInvocationId String?       @map("ai_invocation_id") @db.Uuid
  aiInvocation   AiInvocation? @relation(fields: [aiInvocationId], references: [id], onDelete: SetNull)

  // Tool metadata (for execute + hydrate steps)
  toolName   String? @map("tool_name") @db.VarChar(80)
  toolScope  String? @map("tool_scope") @db.VarChar(60)
  toolTier   String? @map("tool_tier") @db.VarChar(16)
  toolArgs   Json?   @map("tool_args") @db.JsonB
  toolResult Json?   @map("tool_result") @db.JsonB

  // Gate step metadata
  gateDecision Json? @map("gate_decision") @db.JsonB // { gated, rule, checks, approvalId? }

  // LLM voice output + confidence
  output       Json?   @db.JsonB
  confidence   Float?
  errorMessage String? @map("error_message") @db.Text

  durationMs Int?      @map("duration_ms")
  startedAt  DateTime  @default(now()) @map("started_at") @db.Timestamptz
  finishedAt DateTime? @map("finished_at") @db.Timestamptz

  approvals DeskApproval[]

  @@unique([episodeId, sequence])
  @@index([episodeId])
  @@index([toolName])
  @@index([aiInvocationId])
  @@index([agentId])
  @@map("desk_episode_steps")
}

model DeskApproval {
  /// UUIDv7, generated via generateUuidV7() in shared/utils/uuidv7.ts.
  id        String          @id @db.Uuid
  episodeId String          @map("episode_id") @db.Uuid
  episode   DeskEpisode     @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  stepId    String          @map("step_id") @db.Uuid
  step      DeskEpisodeStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  requestedAt    DateTime @default(now()) @map("requested_at") @db.Timestamptz
  expiresAt      DateTime @map("expires_at") @db.Timestamptz
  proposedAction Json     @map("proposed_action") @db.JsonB

  // Claim — multi-operator coordination
  claimedByUserId Int?      @map("claimed_by_user_id")
  claimedBy       User?     @relation("DeskApprovalClaimedBy", fields: [claimedByUserId], references: [id])
  claimedAt       DateTime? @map("claimed_at") @db.Timestamptz

  // Decision
  decision         ApprovalDecision?
  decidedByUserId  Int?              @map("decided_by_user_id")
  decidedBy        User?             @relation("DeskApprovalDecidedBy", fields: [decidedByUserId], references: [id])
  decidedAt        DateTime?         @map("decided_at") @db.Timestamptz
  editedAction     Json?             @map("edited_action") @db.JsonB
  rejectionReason  String?           @map("rejection_reason") @db.Text
  terminateEpisode Boolean           @default(false) @map("terminate_episode") // "Reject & close" flag

  @@index([episodeId, decision])
  @@index([stepId])
  @@index([claimedByUserId])
  @@index([decidedByUserId])
  @@map("desk_approvals")
}

enum MemoryScope {
  ENTITY
  PATTERN
  PLAYBOOK
}

enum MemoryPolarity {
  REINFORCE
  CORRECT
}

model DeskMemory {
  /// UUIDv7, generated via generateUuidV7() in shared/utils/uuidv7.ts.
  id       String    @id @db.Uuid
  tenantId Int       @map("tenant_id")
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId  Int       @map("agent_id")
  agent    DeskAgent @relation(fields: [agentId], references: [id])

  scope    MemoryScope
  polarity MemoryPolarity

  content          String                       @db.Text
  contentEmbedding Unsupported("vector(1536)")? @map("content_embedding")
  entityRef        Json?                        @map("entity_ref") @db.JsonB // structural pointer for entity scope
  entityPredicate  Json?                        @map("entity_predicate") @db.JsonB // reserved for pattern scope

  sourceEpisodeId String?      @map("source_episode_id") @db.Uuid
  sourceEpisode   DeskEpisode? @relation("DeskMemorySource", fields: [sourceEpisodeId], references: [id], onDelete: SetNull)

  // authoredByUserId IS NOT NULL → operator-authored playbook rule (Rules
  // tab). NULL → LLM-extracted memory (Memory tab). Single discriminator
  // for the Rules-vs-Memory split.
  authoredByUserId Int?  @map("authored_by_user_id")
  authoredBy       User? @relation("DeskMemoryAuthoredBy", fields: [authoredByUserId], references: [id], onDelete: SetNull)

  confidence Float   @default(0.8)
  usageCount Int     @default(0) @map("usage_count")
  isActive   Boolean @default(true) @map("is_active")
  isPinned   Boolean @default(false) @map("is_pinned") // pinned rows skip auto-decay

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  expiresAt DateTime? @map("expires_at") @db.Timestamptz

  @@index([tenantId, agentId, isActive])
  @@index([scope, polarity])
  @@index([authoredByUserId])
  @@index([isActive, expiresAt])
  @@index([sourceEpisodeId])
  @@map("desk_memories")
}

// ============================================================================
// Desk — Entity Suppression
// ----------------------------------------------------------------------------
// Records "snooze" decisions on (tenant, responsibility, entity) triples so
// the TriggerService can skip upserting new episodes for entities the user
// has explicitly parked. Only one ACTIVE row per triple (partial unique index,
// WHERE unsuppressed_at IS NULL). `suppress_until = NULL` = forever.
// ============================================================================

model DeskEntitySuppression {
  id                   String       @id @default(uuid(7)) @db.Uuid
  tenantId             Int          @map("tenant_id")
  tenant               Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  responsibilityKey    String       @map("responsibility_key")
  entityType           String       @map("entity_type")
  entityId             String       @map("entity_id")
  suppressUntil        DateTime?    @map("suppress_until") @db.Timestamptz
  reason               String?
  setByUserId          Int          @map("set_by_user_id")
  setByUser            User         @relation("DeskSuppressionSet", fields: [setByUserId], references: [id])
  setAt                DateTime     @default(now()) @map("set_at") @db.Timestamptz
  sourceEpisodeId      String?      @map("source_episode_id") @db.Uuid
  sourceEpisode        DeskEpisode? @relation(fields: [sourceEpisodeId], references: [id], onDelete: SetNull)
  unsuppressedAt       DateTime?    @map("unsuppressed_at") @db.Timestamptz
  unsuppressedByUserId Int?         @map("unsuppressed_by_user_id")
  unsuppressedByUser   User?        @relation("DeskSuppressionUnset", fields: [unsuppressedByUserId], references: [id])

  // NOTE: Active-uniqueness (one active suppression per tenant + responsibility
  // + entity) is enforced via a partial unique SQL index (WHERE unsuppressed_at
  // IS NULL); Prisma cannot express the WHERE clause. Lookup index for the
  // trigger-service hot path is also SQL-only.
  @@index([tenantId, responsibilityKey, entityType, entityId])
  @@index([sourceEpisodeId])
  @@map("desk_entity_suppressions")
}

// ============================================================================
// AGENT RUNTIME — invocation audit + HITL
// ============================================================================

/// Append-only audit of every agent tool invocation.
/// Indexed (tenantId, createdAt desc) for tenant-scoped activity queries.
/// argsRedacted is written by default; argsRaw is populated only during an opt-in 72h debug window.
model AgentInvocationLog {
  /// UUIDv7, generated via generateUuidV7() in shared/utils/uuidv7.ts.
  id       String @id @db.Uuid
  tenantId Int    @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  principalKind  String @map("principal_kind") @db.VarChar(32)
  principalId    String @map("principal_id") @db.VarChar(128)
  principalLabel String @map("principal_label") @db.VarChar(160)

  toolName      String @map("tool_name") @db.VarChar(80)
  scopeRequired String @map("scope_required") @db.VarChar(60)
  hitlTier      String @map("hitl_tier") @db.VarChar(16)

  argsDigest   String @map("args_digest") @db.VarChar(64)
  argsRedacted Json   @map("args_redacted") @db.JsonB
  argsRaw      Json?  @map("args_raw") @db.JsonB

  success    Boolean @default(false)
  durationMs Int?    @map("duration_ms")
  error      String? @db.Text

  outputSummary       String? @map("output_summary") @db.VarChar(500)
  piiReadFlag         Boolean @default(false) @map("pii_read_flag")
  confirmationTokenId String? @map("confirmation_token_id") @db.VarChar(128)
  langfuseTraceId     String? @map("langfuse_trace_id") @db.VarChar(128)
  requestId           String? @map("request_id") @db.VarChar(64)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, principalKind, principalId])
  @@index([tenantId, toolName])
  @@map("agent_invocation_logs")
}

/// Short-lived HITL challenge issued when an external principal attempts a write
/// on a scope whose tier is 'standard' or 'sensitive'. The principal must either
/// re-present the token within TTL (standard) or complete an OTP step-up and then
/// re-present it (sensitive) before the real tool call is executed.
model HitlChallenge {
  id       Int    @id @default(autoincrement())
  tenantId Int    @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  principalKind String @map("principal_kind") @db.VarChar(32)
  principalId   String @map("principal_id") @db.VarChar(128)

  toolName      String @map("tool_name") @db.VarChar(80)
  argsDigest    String @map("args_digest") @db.VarChar(64)
  scopeRequired String @map("scope_required") @db.VarChar(60)
  tier          String @db.VarChar(16)

  stepUpRequired  Boolean @default(false) @map("step_up_required")
  stepUpUserId    Int?    @map("step_up_user_id")
  stepUpCompleted Boolean @default(false) @map("step_up_completed")

  consumedAt DateTime? @map("consumed_at") @db.Timestamptz
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([tenantId, expiresAt])
  @@index([tenantId, principalId, consumedAt])
  @@map("hitl_challenges")
}

// =============================================================================
// AI Cost Telemetry
// =============================================================================
//
// `AiInvocation` is the single LLM/embedding call ledger across every AI
// surface (chat, desk steps, memory, embeddings, knowledge-base ingest).
// One row per model call. Cost is computed at write time from `ModelPricing`
// and denormalized so historical totals stay accurate when prices change.
//
// Distinct from `AgentInvocationLog` above, which audits tool-call metadata.

/// Surface that produced an AI invocation. Used for cost attribution and
/// per-surface budget enforcement. New surfaces are added here, not in code.
enum AiSurface {
  CHAT
  DESK_STEP
  MEMORY_EXTRACT
  EMBEDDING
  KB_INGEST
}

/// Terminal status of an AI invocation as observed by the wrapper.
enum AiInvocationStatus {
  OK
  ERROR
  TIMEOUT
  RATE_LIMITED
  BUDGET_BLOCKED
}

/// Append-only ledger of every LLM and embedding call. Indexed for tenant +
/// surface + time queries.
model AiInvocation {
  /// UUIDv7, generated via generateUuidV7() in shared/utils/uuidv7.ts.
  id       String @id @db.Uuid
  tenantId Int    @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId Int?  @map("user_id")
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  surface  AiSurface
  agentId  String?   @map("agent_id") @db.VarChar(80)
  model    String    @db.VarChar(80)
  provider String    @db.VarChar(40)

  promptTokens     Int  @default(0) @map("prompt_tokens")
  completionTokens Int  @default(0) @map("completion_tokens")
  totalTokens      Int  @default(0) @map("total_tokens")
  cachedTokens     Int? @map("cached_tokens")

  /// Denormalized cost in USD computed at write time from `ModelPricing`. Null
  /// when no matching pricing row was found (the call still gets recorded —
  /// untagged cost is a bug, not a default).
  costUsd   Decimal? @map("cost_usd") @db.Decimal(12, 6)
  latencyMs Int?     @map("latency_ms")

  status    AiInvocationStatus
  errorCode String?            @map("error_code") @db.VarChar(80)

  /// Self-FK used when a single logical call produces multiple model
  /// invocations (e.g. primary + fallback retry, or a tool-call that triggers
  /// a sub-LLM-call). The fallback row references the primary's id.
  parentInvocationId String?        @map("parent_invocation_id") @db.Uuid
  parentInvocation   AiInvocation?  @relation("AiInvocationParentChild", fields: [parentInvocationId], references: [id], onDelete: SetNull)
  childInvocations   AiInvocation[] @relation("AiInvocationParentChild")

  /// Polymorphic linkage to the surface entity. Surfaces churn faster than the
  /// ledger does — we keep a typed linkRef pair here instead of one FK per
  /// surface. `DeskEpisodeStep.aiInvocationId` is the one exception (hot read
  /// path for the desk timeline).
  linkRefType String? @map("link_ref_type") @db.VarChar(40)
  linkRefId   String? @map("link_ref_id") @db.VarChar(64)

  /// Langfuse trace id when Langfuse is configured. Lets the super-admin view
  /// deep-link from a Postgres row back to the trace with prompt + response.
  langfuseTraceId String? @map("langfuse_trace_id") @db.VarChar(128)

  /// Optional idempotency key. When present, duplicate writes (e.g. retried
  /// HTTP calls inside a parser) are no-ops.
  idempotencyKey String? @unique @map("idempotency_key") @db.VarChar(200)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  deskEpisodeSteps DeskEpisodeStep[]

  @@index([userId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, surface, createdAt(sort: Desc)])
  @@index([linkRefType, linkRefId])
  @@index([parentInvocationId])
  @@map("ai_invocations")
}

/// Per-provider/per-model pricing snapshot. Pricing-as-data so we can rotate
/// models without redeploys; `effectiveFromDate` lets us preserve historical
/// pricing for replay/backfill. `cachedInputPerMtokUsd` is nullable because
/// not every provider exposes a separate cached-input price.
model ModelPricing {
  id                    Int       @id @default(autoincrement())
  provider              String    @db.VarChar(40)
  model                 String    @db.VarChar(80)
  inputPerMtokUsd       Decimal   @map("input_per_mtok_usd") @db.Decimal(10, 6)
  outputPerMtokUsd      Decimal   @map("output_per_mtok_usd") @db.Decimal(10, 6)
  cachedInputPerMtokUsd Decimal?  @map("cached_input_per_mtok_usd") @db.Decimal(10, 6)
  effectiveFromDate     DateTime  @map("effective_from_date") @db.Date
  effectiveUntilDate    DateTime? @map("effective_until_date") @db.Date
  notes                 String?   @db.Text
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@unique([provider, model, effectiveFromDate])
  @@index([provider, model, effectiveFromDate(sort: Desc)])
  @@map("model_pricing")
}

/// Per-tenant USD cost guardrail for AI spend. INDEPENDENT of the plan/
/// billing quota system (which counts feature uses) — this caps actual
/// inference dollars to protect margin and stop a runaway agent. Both fire:
/// quota first (cheap counter), then this cost budget.
model TenantAiBudget {
  id       Int    @id @default(autoincrement())
  tenantId Int    @unique @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  dailySoftUsd   Decimal @default(5) @map("daily_soft_usd") @db.Decimal(10, 2)
  dailyHardUsd   Decimal @default(20) @map("daily_hard_usd") @db.Decimal(10, 2)
  monthlySoftUsd Decimal @default(50) @map("monthly_soft_usd") @db.Decimal(10, 2)
  monthlyHardUsd Decimal @default(200) @map("monthly_hard_usd") @db.Decimal(10, 2)

  notes String? @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("tenant_ai_budgets")
}
