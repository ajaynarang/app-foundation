  @@unique([tenantId, addOnId])
  @@index([tenantId, status])
  @@index([addOnId])
  @@map("tenant_add_ons")
}

// ============================================================================
// OUTBOUND WEBHOOK MODELS
// ============================================================================

model WebhookSubscription {
  id          String   @id @default(cuid())
  tenantId    Int      @map("tenant_id")
  url         String   @db.VarChar(2048)
  secret      String   @db.VarChar(255)
  events      String[]
  active      Boolean  @default(true)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant       Tenant               @relation(fields: [tenantId], references: [id])
  deliveryLogs WebhookDeliveryLog[]

  @@index([tenantId, active])
  @@map("webhook_subscriptions")
}

model WebhookDeliveryLog {
  /// App-generated UUIDv7 via generateUuidV7() — time-sortable PK. No
  /// Prisma @default; every create() must pass `id: generateUuidV7()`.
  id             String    @id @db.Uuid
  subscriptionId String    @map("subscription_id")
  event          String    @db.VarChar(100)
  payload        Json      @db.JsonB
  responseStatus Int?      @map("response_status")
  responseBody   String?   @map("response_body") @db.Text
  attempts       Int       @default(0)
  deliveredAt    DateTime? @map("delivered_at") @db.Timestamptz
  failedAt       DateTime? @map("failed_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, createdAt])
  @@map("webhook_delivery_logs")
}

model DomainEventLog {
  /// App-generated UUIDv7 via generateUuidV7() — time-sortable PK. No
  /// Prisma @default; every create() must pass `id: generateUuidV7()`.
  id            String   @id @db.Uuid
  tenantId      Int      @map("tenant_id")
  event         String   @map("event") @db.VarChar(100)
  aggregateType String   @map("aggregate_type") @db.VarChar(50)
  aggregateId   String?  @map("aggregate_id") @db.VarChar(100)
  actorId       String?  @map("actor_id") @db.VarChar(100)
  actorType     String?  @map("actor_type") @db.VarChar(20)
  actorLabel    String?  @map("actor_label") @db.VarChar(100)
  correlationId String?  @map("correlation_id") @db.VarChar(50)
  causationId   String?  @map("causation_id") @db.VarChar(50)
  version       Int      @default(1)
  data          Json     @db.JsonB
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, event])
  @@index([tenantId, aggregateType, aggregateId])
  @@index([correlationId])
  @@map("domain_event_log")
}

/// Permanent queue failures — when a BullMQ job exhausts its retries, the
/// processor persists the envelope + error here so the failure survives Bull's
/// 7-day `failed` set retention and can be replayed by an operator.
model DeadLetterLog {
  /// App-generated UUIDv7 via generateUuidV7() — time-sortable PK. No
  /// Prisma @default; every create() must pass `id: generateUuidV7()`.
  id String @id @db.Uuid

  tenantId Int    @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  queueName String @map("queue_name") @db.VarChar(40)
  jobName   String @map("job_name") @db.VarChar(80)
  bullJobId String @map("bull_job_id") @db.VarChar(120)
  jobDbId   Int?   @map("job_db_id") // FK to Job table when present

  correlationId String? @map("correlation_id") @db.VarChar(120)
  causationId   String? @map("causation_id") @db.VarChar(120)

  payload      Json    @db.JsonB
  errorMessage String  @map("error_message") @db.Text
  errorStack   String? @map("error_stack") @db.Text
  attempts     Int

  failedAt    DateTime  @default(now()) @map("failed_at") @db.Timestamptz
  replayedAt  DateTime? @map("replayed_at") @db.Timestamptz
  replayedBy  String?   @map("replayed_by") @db.VarChar(120)
  replayJobId String?   @map("replay_job_id") @db.VarChar(120)

  @@index([tenantId, queueName, failedAt])
  @@index([bullJobId])
  @@map("dead_letter_logs")
}

// ============================================================================
// OAUTH PROVIDER MODELS
// ============================================================================

model OAuthClient {
  id           Int     @id @default(autoincrement())
  clientId     String  @unique @map("client_id") @db.VarChar(64)
  clientSecret String  @map("client_secret") @db.VarChar(255)
  name         String  @db.VarChar(255)
  description  String? @db.Text

  redirectUris String[] @map("redirect_uris")
  scopes       String[]
  clientType   String   @default("confidential") @map("client_type") @db.VarChar(20)

  tenantId        Int?    @map("tenant_id")
  tenant          Tenant? @relation(fields: [tenantId], references: [id])
  createdByUserId Int?    @map("created_by_user_id")
  createdByUser   User?   @relation("OAuthClientCreator", fields: [createdByUserId], references: [id])

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  authorizationCodes OAuthAuthorizationCode[]
  accessTokens       OAuthAccessToken[]
  refreshTokens      OAuthRefreshToken[]

  @@index([tenantId])
  @@index([createdByUserId])
  @@map("oauth_clients")
}

/// OAuth 2.1 authorization code — short-lived, single-use.
model OAuthAuthorizationCode {
  id   Int    @id @default(autoincrement())
  code String @unique @db.VarChar(128)

  clientId Int         @map("client_id")
  client   OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId   Int         @map("user_id")
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  codeChallenge       String @map("code_challenge") @db.VarChar(128)
  codeChallengeMethod String @default("S256") @map("code_challenge_method") @db.VarChar(10)

  scopes      String[]
  redirectUri String    @map("redirect_uri") @db.VarChar(2048)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz
  usedAt      DateTime? @map("used_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@index([clientId])
  @@index([expiresAt])
  @@map("oauth_authorization_codes")
}

/// OAuth 2.1 access token — stores hash for revocation checks.
model OAuthAccessToken {
  id        Int    @id @default(autoincrement())
  tokenHash String @unique @map("token_hash") @db.VarChar(128)

  clientId Int         @map("client_id")
  client   OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId   Int         @map("user_id")
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  scopes    String[]
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@index([clientId])
  @@index([expiresAt])
  @@map("oauth_access_tokens")
}

/// OAuth 2.1 refresh token — long-lived, rotated on use.
model OAuthRefreshToken {
  id        Int    @id @default(autoincrement())
  tokenHash String @unique @map("token_hash") @db.VarChar(128)

  clientId Int         @map("client_id")
  client   OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId   Int         @map("user_id")
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  scopes           String[]
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz
  rotatedAt        DateTime? @map("rotated_at") @db.Timestamptz
  replacedByHash   String?   @map("replaced_by_hash") @db.VarChar(128)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  originalIssuedAt DateTime  @default(now()) @map("original_issued_at") @db.Timestamptz

  @@index([userId])
  @@index([clientId])
  @@index([expiresAt])
  @@map("oauth_refresh_tokens")
}

// ============================================================================
// FEEDBACK
// ============================================================================

enum FeedbackStatus {
  NEW
  REVIEWED
  RESOLVED
}

model Feedback {
