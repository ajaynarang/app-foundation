// ============================================================================
// AI CONVERSATION MODELS
// ============================================================================

model Conversation {
  id             Int    @id @default(autoincrement())
  conversationId String @unique @map("conversation_id") @db.VarChar(80)

  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  tenantId Int?    @map("tenant_id")

  user   User? @relation(fields: [userId], references: [id])
  userId Int?  @map("user_id")

  userMode String  @map("user_mode") @db.VarChar(20)
  title    String? @db.VarChar(255)
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  messages      ConversationMessage[]
  supportTicket SupportTicket?
  sessions      ConversationSession[]

  @@index([tenantId, userMode, title]) // Fast load message thread lookup
  @@index([tenantId, userId, createdAt])
  @@map("conversations")
}

// Opaque session token for anonymous prospect conversations.
// Per the ID convention (opaque tokens never live on the entity row),
// this replaces the legacy Conversation.sessionToken column. The dedicated table
// adds expiry, revoke, and audit fields the embedded column never had.
model ConversationSession {
  id             Int          @id @default(autoincrement())
  conversationId Int          @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Nullable to mirror Conversation.tenantId — prospect (pre-signup) conversations
  // don't yet belong to a tenant. Authenticated conversations populate this.
  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  tenantId Int?    @map("tenant_id")

  token      String    @unique @db.VarChar(32)
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz
  lastSeenAt DateTime? @map("last_seen_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([conversationId])
  @@index([tenantId, createdAt])
  @@map("conversation_sessions")
}

model ConversationMessage {
  id        Int    @id @default(autoincrement())
  messageId String @unique @map("message_id") @db.VarChar(50)

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId Int          @map("conversation_id")

  role      String  @db.VarChar(20)
  content   String  @db.Text
  inputMode String  @map("input_mode") @db.VarChar(10)
  intent    String? @db.VarChar(50)
  card      Json?   @db.JsonB
  action    Json?   @db.JsonB
  speakText String? @map("speak_text") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([conversationId, createdAt])
  @@map("conversation_messages")
}

// ============================================================================
// AI KNOWLEDGE BASE (RAG)
// ============================================================================

/// Platform-global knowledge base (seeded from apps/backend/content/knowledge-base).
/// Intentionally NOT tenant-scoped — every tenant's assistant shares it. Add a
/// tenantId column if your product needs per-tenant knowledge.
model KnowledgeDocument {
  id         Int    @id @default(autoincrement())
  documentId String @unique @map("document_id") @db.VarChar(50)

  title      String                   @db.VarChar(255)
  content    String                   @db.Text
  contentTsv Unsupported("tsvector")? @map("content_tsv")

  // Metadata for filtering
  documentType String   @map("document_type") @db.VarChar(50)
  audience     String   @db.VarChar(50)
  category     String   @db.VarChar(100)
  keywords     String[] @default([])

  // Embedding (stored as pgvector, managed via raw SQL)
  embedding Unsupported("vector(1536)")?

  // Chunking metadata
  chunkIndex  Int     @default(0) @map("chunk_index")
  parentDocId String? @map("parent_doc_id") @db.VarChar(50)
  totalChunks Int     @default(1) @map("total_chunks")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([documentType, audience])
  @@index([audience])
  @@index([category])
  @@map("knowledge_documents")
}

