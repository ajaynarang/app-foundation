{
  "name": "@appshore/platform",
  "version": "0.1.0",
  "private": true,
  "description": "AppShore platform — Prisma-coupled SaaS foundation: auth, tenancy, queues, storage, health, platform domains",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json",
    "./*": "./dist/*.js"
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "jest --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "^22.10.7",
    "jest": "30.2.0",
    "ts-jest": "29.4.6",
    "typescript": "^5.9.3"
  }
}
